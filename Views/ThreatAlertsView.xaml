<UserControl x:Class="RansomGuard.Views.ThreatAlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            
            <!-- Summary Stats (4 severity cards) -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Critical -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CRITICAL" FontSize="10" FontWeight="Bold"
                                      Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Right">
                                <Path Data="M12 21a1 1 0 0 1-1-1v-5l-4.33 2.5a1 1 0 1 1-1-1.73L10 13.27V8.73l-4.33-2.5a1 1 0 1 1 1-1.73L11 7v-5a1 1 0 1 1 2 0v5l4.33-2.5a1 1 0 1 1 1 1.73L14 8.73v4.54l4.33 2.5a1 1 0 1 1-1 1.73L13 15v5a1 1 0 0 1-1 1z" 
                                      Fill="{StaticResource ErrorBrush}"/>
                            </Viewbox>
                        </Grid>
                        <TextBlock Text="{Binding CriticalThreatsCount}" FontSize="40" FontWeight="ExtraBold" 
                                  Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                      Fill="{StaticResource SecondaryBrush}"/>
                            </Viewbox>
                            <TextBlock Text="No active breaches" Style="{StaticResource TextSmall}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- High -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="HIGH" FontSize="10" FontWeight="Bold"
                                      Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Right">
                                <Path Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" 
                                      Fill="{StaticResource TertiaryContainerBrush}"/>
                            </Viewbox>
                        </Grid>
                        <TextBlock Text="{Binding HighThreatsCount}" FontSize="40" FontWeight="ExtraBold" 
                                   Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15l-4-4 1.41-1.41L12 14.17l7.59-7.59L21 8l-8 9z" 
                                      Fill="{StaticResource TertiaryContainerBrush}"/>
                            </Viewbox>
                            <TextBlock Text="Immediate attention" Foreground="{StaticResource TertiaryContainerBrush}" FontSize="10" FontWeight="Medium"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Medium -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="MEDIUM" FontSize="10" FontWeight="Bold"
                                      Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Right">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                                      Fill="{StaticResource PrimaryBrush}"/>
                            </Viewbox>
                        </Grid>
                        <TextBlock Text="{Binding MediumThreatsCount}" FontSize="40" FontWeight="ExtraBold" 
                                   Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                <Path Data="M11 7h2v2h-2zm0 4h2v6h-2zm1-9C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" 
                                      Fill="{StaticResource OnSurfaceVariantBrush}"/>
                            </Viewbox>
                            <TextBlock Text="Under investigation" Style="{StaticResource TextSmall}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Low -->
                <Border Grid.Column="6" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="LOW" FontSize="10" FontWeight="Bold"
                                      Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Right">
                                <Path Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" 
                                      Fill="{StaticResource SecondaryBrush}"/>
                            </Viewbox>
                        </Grid>
                        <TextBlock Text="{Binding LowThreatsCount}" FontSize="40" FontWeight="ExtraBold" 
                                   Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                <Path Data="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79 s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 2.5-.98 4.81-2.73 6.56-3.52 3.49-9.21 3.49-12.73 0-3.52-3.5-3.52-9.18 0-12.68 3.52-3.5 9.21-3.5 12.73 0l2.84-2.92V10.12z" 
                                      Fill="{StaticResource OnSurfaceVariantBrush}"/>
                            </Viewbox>
                            <TextBlock Text="Routine events" Style="{StaticResource TextSmall}" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Alerts Table -->
            <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8">
                <StackPanel>
                    <!-- Filter Toolbar -->
                    <Border Background="{StaticResource SurfaceContainerHighestBrush}" 
                           Padding="16" CornerRadius="12,12,0,0" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <!-- Severity Filter Box -->
                                <Border Background="{StaticResource SurfaceContainerBrush}" 
                                        BorderBrush="{StaticResource OutlineVariantBrush}" 
                                        BorderThickness="1" CornerRadius="4" Padding="12,2" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="SEVERITY:" FontSize="10" FontWeight="Bold"
                                                  Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Width="120" Height="28" 
                                                 SelectedIndex="{Binding SelectedSeverityIndex}"
                                                 Style="{StaticResource ModernComboBox}"
                                                 VerticalContentAlignment="Center">
                                            <ComboBoxItem Content="All Severities"/>
                                            <ComboBoxItem Content="Critical Only"/>
                                            <ComboBoxItem Content="High Only"/>
                                            <ComboBoxItem Content="Medium"/>
                                            <ComboBoxItem Content="Low"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <!-- Date Range Filter Box -->
                                <Border Background="{StaticResource SurfaceContainerBrush}" 
                                        BorderBrush="{StaticResource OutlineVariantBrush}" 
                                        BorderThickness="1" CornerRadius="4" Padding="12,2">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="DATE RANGE:" FontSize="10" FontWeight="Bold"
                                                  Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Width="130" Height="28" 
                                                 SelectedIndex="{Binding SelectedDateRangeIndex}"
                                                 Style="{StaticResource ModernComboBox}"
                                                 VerticalContentAlignment="Center">
                                            <ComboBoxItem Content="Last 24 Hours"/>
                                            <ComboBoxItem Content="Last 7 Days"/>
                                            <ComboBoxItem Content="Last 30 Days"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Button HorizontalAlignment="Right" Padding="16,8" Background="#1aadc6ff" BorderThickness="0"
                                    Command="{Binding SyncLogsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                        <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" 
                                              Fill="{StaticResource PrimaryBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="SYNC LOGS" FontSize="11" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Threaded Timeline Area -->
                    <Border Padding="24" Background="Transparent">
                        <ItemsControl ItemsSource="{Binding Threats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Timeline Thread -->
                                        <Grid Grid.Column="0">
                                            <Rectangle Width="2" Fill="{StaticResource OutlineVariantBrush}" HorizontalAlignment="Center" Margin="0,24,0,-32" Opacity="0.2"/>
                                            <Ellipse Width="16" Height="16" Fill="{StaticResource SurfaceContainerHighestBrush}" 
                                                    Stroke="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" 
                                                    StrokeThickness="3" VerticalAlignment="Top" Margin="0,20,0,0"/>
                                        </Grid>
                                        
                                        <!-- Alert Card -->
                                        <Border Grid.Column="1" Background="{StaticResource SurfaceContainerHighBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,8"
                                                BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" 
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <StackPanel Grid.Row="0" Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <Border Background="{StaticResource SurfaceContainerBrush}" Padding="8,4" CornerRadius="4" Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding Severity}" Foreground="{StaticResource TertiaryBrush}" FontWeight="Black" FontSize="9"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MMM dd, yyyy • HH:mm:ss}'}" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,8" FontStyle="Italic"/>
                                                    <TextBlock Text="{Binding Path}" Style="{StaticResource TextMono}" FontSize="12" Opacity="0.7"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                    <Button Style="{StaticResource IconButton}" Margin="0,0,4,0" ToolTip="Ignore" Height="32" Width="32"
                                            Command="{Binding DataContext.IgnoreThreatCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                                        <Viewbox Width="16" Height="16">
                                                            <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" Fill="{StaticResource OnSurfaceBrush}"/>
                                                        </Viewbox>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButton}" ToolTip="Quarantine" Height="32" Width="32"
                                            Command="{Binding DataContext.QuarantineThreatCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                                        <Viewbox Width="16" Height="16">
                                                            <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" Fill="{StaticResource OnSurfaceBrush}"/>
                                                        </Viewbox>
                                                    </Button>
                                                </StackPanel>
                                                
                                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource SurfaceContainerHighestBrush}" CornerRadius="6" Padding="12,8" Margin="0,16,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="PROCESS CONTEXT:" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="{Binding ProcessName}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" • PID: " FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ProcessId}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource SecondaryBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>


                    <!-- Pagination / Footer -->
                    <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,1,0,0" Padding="24,12">
                        <Grid>
                            <TextBlock Text="{Binding PaginationText}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="← Previous" Style="{StaticResource NativeButton}" 
                                       Command="{Binding PreviousPageCommand}"
                                       IsEnabled="{Binding HasPrevious}"
                                       FontSize="10" FontWeight="Bold"
                                       Padding="12,6" Margin="0,0,16,0"/>
                                <Button Content="Next →" Style="{StaticResource NativeButton}" 
                                       Command="{Binding NextPageCommand}"
                                       IsEnabled="{Binding HasNext}"
                                       FontSize="10" FontWeight="Bold"
                                       Padding="12,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

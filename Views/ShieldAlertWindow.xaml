<Window x:Class="RansomGuard.Views.ShieldAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CRITICAL SECURITY ALERT" WindowState="Maximized"
        WindowStyle="None" AllowsTransparency="True" Background="#cc000000"
        Topmost="True" ShowInTaskbar="False">
    
    <Window.Resources>
        <Storyboard x:Key="OnLoaded">
            <DoubleAnimation Storyboard.TargetName="MainBorder" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6"/>
            <DoubleAnimation Storyboard.TargetName="MainScale" Storyboard.TargetProperty="ScaleX"
                             From="0.8" To="1" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase Oscillations="1" Springiness="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainScale" Storyboard.TargetProperty="ScaleY"
                             From="0.8" To="1" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase Oscillations="1" Springiness="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource OnLoaded}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border x:Name="MainBorder" CornerRadius="24" Margin="20" Background="#111111" BorderBrush="#ff3333" BorderThickness="2" Opacity="0"
                VerticalAlignment="Center" HorizontalAlignment="Center" Width="900" Height="600">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Color="#ff0000" Opacity="0.5" ShadowDepth="0"/>
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform x:Name="MainScale" CenterX="450" CenterY="300"/>
            </Border.RenderTransform>

            <Grid Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Orientation="Vertical" Grid.Row="0" HorizontalAlignment="Center">
                    <TextBlock Text="⚠️ CRITICAL THREAT DETECTED ⚠️" FontSize="32" FontWeight="Bold" Foreground="#ff5252" HorizontalAlignment="Center"/>
                    <Border Height="2" Background="#ff5252" Width="400" Margin="0,15,0,0" Opacity="0.3"/>
                </StackPanel>

                <!-- Content -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,30,0,30">
                    <TextBlock Text="Mass Encryption Activity Identified" FontSize="24" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="MALICIOUS PROCESS" Foreground="#888888" FontSize="12" FontWeight="Bold"/>
                            <TextBlock x:Name="ProcessText" Text="Unknown.exe (PID: 0)" Foreground="White" FontSize="18" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="AFFECTED FILES" Foreground="#888888" FontSize="12" FontWeight="Bold"/>
                            <TextBlock x:Name="FilesText" Text="0 Files" Foreground="White" FontSize="18" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#222222" CornerRadius="12" Margin="0,30,0,0" Padding="20">
                        <TextBlock Text="RansomGuard has intercepted high-velocity file modifications. To prevent data loss, the malicious process will be terminated and affected files will be moved to secure quarantine." 
                                   Foreground="#cccccc" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" LineHeight="20"/>
                    </Border>
                </StackPanel>

                <!-- Countdown -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock x:Name="TimerText" Text="AUTOMATIC MITIGATION IN 5 SECONDS" FontSize="14" FontWeight="Bold" Foreground="#ffab40" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="CountdownProgress" Height="4" Width="300" Margin="0,10,0,0" Maximum="500" Value="500" Foreground="#ffab40" Background="#333333" BorderThickness="0"/>
                </StackPanel>

                <!-- Actions -->
                <UniformGrid Grid.Row="3" Columns="2" Rows="1">
                    <Button x:Name="YesButton" Content="EXECUTE NOW" Height="50" Margin="0,0,10,0" Click="YesButton_Click"
                            Background="#ff5252" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="NoButton" Content="WAIT / CANCEL" Height="50" Margin="10,0,0,0" Click="NoButton_Click"
                            Background="#333333" Foreground="White" FontWeight="Bold" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Resources>
                    </Button>
                </UniformGrid>
            </Grid>
        </Border>
    </Grid>
</Window>

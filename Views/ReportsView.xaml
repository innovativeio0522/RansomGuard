<UserControl x:Class="RansomGuard.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="Segoe UI">
    
    <UserControl.Resources>
        <!-- Ultra-SleekActionButton Style -->
        <Style x:Key="SleekActionButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource SurfaceContainerHighest}" Offset="0"/>
                        <GradientStop Color="{StaticResource SurfaceContainerHigh}" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineVariantBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="{StaticResource SurfaceBright}" Offset="0"/>
                                            <GradientStop Color="{StaticResource SurfaceContainerHighest}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" Opacity="0.3" ShadowDepth="0" Color="{StaticResource Primary}"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource OutlineVariantBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ultra-SleekPrimaryActionButton Style -->
        <Style x:Key="SleekPrimaryActionButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource PrimaryContainer}" Offset="0"/>
                        <GradientStop Color="{StaticResource Primary}" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource OnPrimaryContainerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryContainerBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="{StaticResource PrimaryFixed}" Offset="0"/>
                                            <GradientStop Color="{StaticResource PrimaryContainer}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="0" Color="{StaticResource Primary}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel Margin="0,0,0,16">
            <!-- Header & Export Actions -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Reports Center" FontSize="20" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,0"/>
                    <TextBlock Text="System health and threat intelligence summary for the last 30 days." FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button Style="{StaticResource SleekActionButton}" Command="{Binding RefreshCommand}" Padding="16,1" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="10" Height="10" Margin="0,0,8,0">
                                <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" 
                                      Fill="{StaticResource OnSurfaceVariantBrush}"/>
                            </Viewbox>
                            <TextBlock Text="Sync Intelligence" FontSize="10" FontWeight="Medium" Foreground="{StaticResource OnSurfaceBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SleekActionButton}" 
                            Command="{Binding ExportToPdfCommand}" 
                            Padding="16,1" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M10,13L8,15L10,17M14,13L16,15L14,17" 
                                  Fill="{StaticResource OnSurfaceVariantBrush}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Export to PDF" FontSize="10" FontWeight="Medium" Foreground="{StaticResource OnSurfaceBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SleekPrimaryActionButton}" 
                            Command="{Binding ExportToCsvCommand}"
                            Padding="16,1">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" 
                                  Fill="{StaticResource OnPrimaryContainerBrush}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Export to CSV" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnPrimaryContainerBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Summary Bento Grid -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Weekly Detections Card -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" Padding="16" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.1"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Weekly Detections" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="{Binding WeeklyDetectionsCount}" FontSize="24" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource SecondaryBrush}" Opacity="0.1" Padding="6" CornerRadius="2">
                                <Path Data="M16,18L16,6L18.5,8.5L17.08,9.92L16,8.84L16,18M8.5,8.5L7.08,9.92L6,8.84L6,18L12,12L6,6L16,6L16,8H10.5L8.5,10L6.5,8H16" 
                                      Fill="{StaticResource SecondaryBrush}" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="{Binding WeeklyDetectionsTrendText}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Most Common Threat Card -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" Padding="16" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.1"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Most Common Threat Type" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="{Binding MostCommonThreatType}" FontSize="24" FontWeight="ExtraBold" Foreground="{StaticResource TertiaryContainerBrush}" Margin="0,2,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource TertiaryContainerBrush}" Opacity="0.1" Padding="6" CornerRadius="2">
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1ZM12,11.99H19C18.47,16.11 15.72,19.78 12,20.93V12H5V6.3L12,3.19V11.99Z" 
                                      Fill="{StaticResource TertiaryContainerBrush}" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="{Binding CommonThreatDetail}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TertiaryContainerBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts Section -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Line Chart: Threat Detections Over 30 Days -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" Padding="20" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.05"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <Grid Margin="0,0,0,24">
                            <TextBlock Text="Threat Detections Over 30 Days" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                        </Grid>
                        
                        <!-- Chart Area -->
                        <Border Height="240" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
                            <lvc:CartesianChart Series="{Binding DetectionSeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" 
                                                LegendPosition="Hidden"/>
                        </Border>

                        <!-- Metrics Content (Filling the empty space) -->
                        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="4" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Month Total -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="MONTH TOTAL" FontSize="8" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="{Binding MonthlyDetectionsCount}" FontSize="14" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{StaticResource OutlineVariantBrush}" Width="1" Height="16" Opacity="0.1" VerticalAlignment="Center"/>

                                <!-- Peak Day -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="DAILY PEAK" FontSize="8" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="{Binding PeakDetectionCount}" FontSize="14" FontWeight="ExtraBold" Foreground="{StaticResource TertiaryContainerBrush}" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border Grid.Column="3" Background="{StaticResource OutlineVariantBrush}" Width="1" Height="16" Opacity="0.1" VerticalAlignment="Center"/>

                                <!-- Daily Avg -->
                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                    <TextBlock Text="DAILY AVG" FontSize="8" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="{Binding AverageDetectionsCount}" FontSize="14" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Bar Chart: Threat Distribution -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" Padding="20" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.05"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Text="Threat Distribution by Category" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,24"/>
                        
                        <Border Height="240">
                            <lvc:PieChart Series="{Binding DistributionSeries}" 
                                          LegendPosition="Bottom" 
                                          LegendTextSize="10"
                                          LegendTextPaint="{Binding LegendTextPaint}"/>
                        </Border>

                        <!-- Info Box -->
                        <Border Background="{StaticResource SurfaceContainerHighestBrush}" Padding="16" CornerRadius="2" Opacity="0.3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.1"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M13,17H11V15H13V17M13,13H11V7H13V13Z" 
                                      Fill="{StaticResource PrimaryBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ransomware activity has seen a localized spike in APAC regions. Recommended: Update endpoint protocols." 
                                           FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" Width="200" LineHeight="14"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Timeline Section -->
            <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="20" CornerRadius="2">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.05"/>
                </Border.BorderBrush>
                <StackPanel>
                    <TextBlock Text="Anomalous Activity Timeline" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,20"/>
                    
                    <ItemsControl ItemsSource="{Binding RecentSignificantThreats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,32">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Timeline Dot -->
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" BorderBrush="{StaticResource TertiaryContainerBrush}" BorderThickness="2" VerticalAlignment="Top">
                                        <Ellipse Width="8" Height="8" Fill="{StaticResource TertiaryContainerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <!-- Event Content -->
                                    <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                        <TextBlock Text="{Binding Timestamp, StringFormat=f}" FontSize="10" FontWeight="ExtraBold" Foreground="{StaticResource TertiaryContainerBrush}"/>
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,4,0,8"/>
                                        <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="16" CornerRadius="2">
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" LineHeight="18"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

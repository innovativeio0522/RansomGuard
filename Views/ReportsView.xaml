<UserControl x:Class="RansomGuard.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel Margin="0,0,0,32">
            <!-- Header & Export Actions -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Reports Center" FontSize="28" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,0"/>
                    <TextBlock Text="System health and threat intelligence summary for the last 30 days." FontSize="13" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="16,8" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20M10,13L8,15L10,17M14,13L16,15L14,17" 
                                  Fill="{StaticResource OnSurfaceVariantBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Export to PDF" FontSize="11" FontWeight="Medium" Foreground="{StaticResource OnSurfaceBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" 
                                  Fill="{StaticResource OnPrimaryContainerBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0"/>
                            <TextBlock Text="Export to CSV" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OnPrimaryContainerBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Summary Bento Grid -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Weekly Detections Card -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" Padding="24" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.1"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Weekly Detections" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="1,428" FontSize="36" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource SecondaryBrush}" Opacity="0.1" Padding="8" CornerRadius="2">
                                <Path Data="M16,18L16,6L18.5,8.5L17.08,9.92L16,8.84L16,18M8.5,8.5L7.08,9.92L6,8.84L6,18L12,12L6,6L16,6L16,8H10.5L8.5,10L6.5,8H16" 
                                      Fill="{StaticResource SecondaryBrush}" Width="16" Height="16" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                            <TextBlock Text="-12.4%" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>
                            <TextBlock Text=" compared to last week" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Most Common Threat Card -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" Padding="24" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.1"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Most Common Threat Type" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="Ransomware" FontSize="36" FontWeight="ExtraBold" Foreground="{StaticResource TertiaryContainerBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{StaticResource TertiaryContainerBrush}" Opacity="0.1" Padding="8" CornerRadius="2">
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1ZM12,11.99H19C18.47,16.11 15.72,19.78 12,20.93V12H5V6.3L12,3.19V11.99Z" 
                                      Fill="{StaticResource TertiaryContainerBrush}" Width="16" Height="16" Stretch="Uniform"/>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                            <TextBlock Text="High Risk" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TertiaryContainerBrush}"/>
                            <TextBlock Text=" Detected in 42% of events" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="4,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Charts Section -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Line Chart: Threat Detections Over 30 Days -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" Padding="32" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.05"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <Grid Margin="0,0,0,32">
                            <TextBlock Text="Threat Detections Over 30 Days" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="INBOUND" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SecondaryBrush}" Margin="16,0,8,0"/>
                                <TextBlock Text="MITIGATED" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Chart Area (High-Fidelity Visualization) -->
                        <Border Height="256" Background="Transparent" BorderThickness="0" Margin="0,0,0,16">
                            <Grid>
                                <!-- Background Grid Lines (Responsive) -->
                                <UniformGrid Columns="1" Rows="4" Opacity="0.1">
                                    <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                    <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                    <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                    <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                </UniformGrid>
                                
                                <!-- Area Gradients & Data Paths -->
                                <Viewbox Stretch="Fill">
                                    <Grid Width="600" Height="256">
                                        <!-- Mitigated Series (Secondary) -->
                                        <Path Data="M 0,180 L 50,160 L 100,190 L 150,110 L 200,140 L 250,70 L 300,120 L 350,150 L 400,90 L 450,170 L 500,130 L 550,160 L 600,100" 
                                              Stroke="{StaticResource SecondaryBrush}" StrokeThickness="2" Opacity="0.8">
                                            <Path.Effect>
                                                <DropShadowEffect Color="{StaticResource Secondary}" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                            </Path.Effect>
                                        </Path>
                                        <Path Data="M 0,256 L 0,180 L 50,160 L 100,190 L 150,110 L 200,140 L 250,70 L 300,120 L 350,150 L 400,90 L 450,170 L 500,130 L 550,160 L 600,100 L 600,256 Z" 
                                              Opacity="0.05">
                                            <Path.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="{StaticResource Secondary}" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Path.Fill>
                                        </Path>

                                        <!-- Inbound Series (Primary) -->
                                        <Path Data="M 0,150 L 50,130 L 100,160 L 150,80 L 200,110 L 250,40 L 300,90 L 350,120 L 400,60 L 450,140 L 500,100 L 550,130 L 600,70" 
                                              Stroke="{StaticResource PrimaryBrush}" StrokeThickness="3">
                                            <Path.Effect>
                                                <DropShadowEffect Color="{StaticResource Primary}" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                            </Path.Effect>
                                        </Path>
                                        <Path Data="M 0,256 L 0,150 L 50,130 L 100,160 L 150,80 L 200,110 L 250,40 L 300,90 L 350,120 L 400,60 L 450,140 L 500,100 L 550,130 L 600,70 L 600,256 Z" 
                                              Opacity="0.1">
                                            <Path.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="{StaticResource Primary}" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Path.Fill>
                                        </Path>
                                    </Grid>
                                </Viewbox>
                                
                                <!-- Day Labels (Staggered) -->
                                <UniformGrid Columns="4" VerticalAlignment="Bottom" Margin="0,0,0,-24">
                                    <TextBlock Text="DAY 1" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" TextAlignment="Center"/>
                                    <TextBlock Text="DAY 10" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" TextAlignment="Center"/>
                                    <TextBlock Text="DAY 20" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" TextAlignment="Center"/>
                                    <TextBlock Text="DAY 30" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" TextAlignment="Center"/>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Bar Chart: Threat Distribution -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" Padding="32" CornerRadius="2">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.05"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Text="Threat Distribution by Category" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,32"/>
                        
                        <!-- Ransomware -->
                        <StackPanel Margin="0,0,0,24">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Ransomware" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="42%" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TertiaryContainerBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="6" Background="{StaticResource SurfaceContainerHighestBrush}" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42*"/>
                                        <ColumnDefinition Width="58*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource TertiaryContainerBrush}" CornerRadius="3"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Malware -->
                        <StackPanel Margin="0,0,0,24">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Malware" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="35%" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="6" Background="{StaticResource SurfaceContainerHighestBrush}" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="35*"/>
                                        <ColumnDefinition Width="65*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" CornerRadius="3"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Adware -->
                        <StackPanel Margin="0,0,0,48">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Adware" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="23%" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="6" Background="{StaticResource SurfaceContainerHighestBrush}" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="23*"/>
                                        <ColumnDefinition Width="77*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}" CornerRadius="3"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Info Box -->
                        <Border Background="{StaticResource SurfaceContainerHighestBrush}" Padding="16" CornerRadius="2" Opacity="0.3">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.1"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M13,17H11V15H13V17M13,13H11V7H13V13Z" 
                                      Fill="{StaticResource PrimaryBrush}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Ransomware activity has seen a localized spike in APAC regions. Recommended: Update endpoint protocols." 
                                           FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" Width="240" LineHeight="16"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Threat Timeline -->
            <Border Background="{StaticResource SurfaceContainerBrush}" Padding="32" CornerRadius="2">
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource OutlineVariant}" Opacity="0.1"/>
                </Border.BorderBrush>
                <StackPanel>
                    <TextBlock Text="Anomalous Activity Timeline" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,32"/>
                    
                    <!-- Event 1 - Critical -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Timeline Dot -->
                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" BorderBrush="{StaticResource TertiaryContainerBrush}" BorderThickness="2" VerticalAlignment="Top">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource TertiaryContainerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Event Content -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="02:14 AM Today" FontSize="10" FontWeight="ExtraBold" Foreground="{StaticResource TertiaryContainerBrush}"/>
                            <TextBlock Text="Data Exfiltration Blocked" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,4,0,8"/>
                            <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="16" CornerRadius="2">
                                <TextBlock Text="System intercepted multiple outgoing connections to 185.x.x.x originating from HR-Node-4. Access revoked and host isolated within 42ms." 
                                           FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" LineHeight="18"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Event 2 - Success -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Timeline Dot -->
                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" BorderBrush="{StaticResource SecondaryBrush}" BorderThickness="2" VerticalAlignment="Top">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource SecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Event Content -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Yesterday" FontSize="10" FontWeight="ExtraBold" Foreground="{StaticResource SecondaryBrush}"/>
                            <TextBlock Text="Core Security Patch" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,4,0,8"/>
                            <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="16" CornerRadius="2">
                                <TextBlock Text="Auto-remediation successful for CVE-2024-1290 across 40 nodes. System integrity verified." 
                                           FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" LineHeight="18"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Event 3 - Info -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Timeline Dot -->
                        <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" VerticalAlignment="Top">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Event Content -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                            <TextBlock Text="Mar 12, 2024" FontSize="10" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="User Audit Logged" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,4,0,8"/>
                            <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="16" CornerRadius="2">
                                <TextBlock Text="Full system audit completed for node Admin_A. 0 discrepancies found." 
                                           FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" TextWrapping="Wrap" LineHeight="18"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

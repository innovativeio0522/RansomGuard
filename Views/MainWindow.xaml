<Window x:Class="RansomGuard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RansomGuard.Views"
        xmlns:vm="clr-namespace:RansomGuard.ViewModels"
        Title="RansomGuard - DETECT. PROTECT. RECOVER." 
        x:Name="RootWindow"
        WindowStartupLocation="Manual"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        MinWidth="900" MinHeight="600"
        WindowStyle="None"
        Icon="/Assets/Icons/RansomGuard.png">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Map ViewModels to Views -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ThreatAlertsViewModel}">
            <views:ThreatAlertsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QuarantineViewModel}">
            <views:QuarantineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProcessMonitorViewModel}">
            <views:ProcessMonitorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FileActivityViewModel}">
            <views:FileActivityView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>

        <Style x:Key="SidebarMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BackgroundBorder" Background="{TemplateBinding Background}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"/>
                            <Border x:Name="HoverOverlay" Background="White" Opacity="0" CornerRadius="8"/>
                            <ContentPresenter x:Name="Content" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="14,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.05" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#c2c6d6"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="Dashboard"/>
                        <Condition Binding="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:DashboardViewModel}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1a313540"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="ThreatAlerts"/>
                        <Condition Binding="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:ThreatAlertsViewModel}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1a313540"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="Quarantine"/>
                        <Condition Binding="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:QuarantineViewModel}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1a313540"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="ProcessMonitor"/>
                        <Condition Binding="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:ProcessMonitorViewModel}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1a313540"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="FileActivity"/>
                        <Condition Binding="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:FileActivityViewModel}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1a313540"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="Reports"/>
                        <Condition Binding="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:ReportsViewModel}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1a313540"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="Settings"/>
                        <Condition Binding="{Binding DataContext.CurrentView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource TypeToBooleanConverter}, ConverterParameter={x:Type vm:SettingsViewModel}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#1a313540"/>
                    <Setter Property="BorderThickness" Value="0,0,3,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource PrimaryContainerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <TextBlock x:Name="Placeholder" Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                       Foreground="{TemplateBinding Foreground}" Opacity="0.3" 
                                       Margin="2,0,0,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceVariantBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, ElementName=RootWindow}" Value="Maximized">
                        <!-- Removed Margin 8, WM_GETMINMAXINFO now perfectly constraints to screen bounds -->
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar: collapsible -->
            <ColumnDefinition x:Name="SidebarColumn" Width="180"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <!-- Custom Title Bar: 28px -->
            <RowDefinition Height="28"/>
            <!-- Header Bar: 52px -->
            <RowDefinition Height="52"/>
            <!-- Main Content -->
            <RowDefinition Height="*"/>
            <!-- Status Bar: 26px -->
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- LEFT SIDEBAR NAVIGATION -->
        <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" 
                Background="#0f131d" 
                BorderBrush="{StaticResource OutlineVariantBrush}" 
                BorderThickness="0,0,1,0"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Logo -->
                    <RowDefinition Height="*"/>    <!-- Nav -->
                    <RowDefinition Height="Auto"/> <!-- Profile -->
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <Border Grid.Row="0" Height="72" Padding="12,0" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon (always visible) -->
                        <Image Grid.Column="0" Source="/Assets/Icons/RansomGuard.png" Width="28" Height="28"
                               VerticalAlignment="Center"/>

                        <!-- Title text (hidden when collapsed) -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                    Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                            <TextBlock Text="THE SENTINEL" Foreground="{StaticResource PrimaryBrush}" 
                                       FontWeight="Black" FontSize="13"/>
                            <TextBlock Text="CYBERSECURITY NODE" Foreground="{StaticResource OnSurfaceVariantBrush}" 
                                       FontSize="7" FontWeight="Bold" Opacity="0.5" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Toggle button (hidden when collapsed) -->
                        <Button Grid.Column="2" Command="{Binding ToggleSidebarCommand}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Width="26" Height="26" Padding="0" VerticalAlignment="Center"
                                Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                            <Viewbox Width="13" Height="13">
                                <Path Data="M3 18H21V16H3V18ZM3 13H21V11H3V13ZM3 6V8H21V6H3Z" Fill="{StaticResource OnSurfaceVariantBrush}"/>
                            </Viewbox>
                        </Button>

                        <!-- Expand button (visible only when collapsed, overlays icon column) -->
                        <Button Grid.Column="0" Command="{Binding ToggleSidebarCommand}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Width="26" Height="26" Padding="0" VerticalAlignment="Bottom" Margin="0,0,0,4"
                                Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Viewbox Width="13" Height="13">
                                <Path Data="M3 18H21V16H3V18ZM3 13H21V11H3V13ZM3 6V8H21V6H3Z" Fill="{StaticResource OnSurfaceVariantBrush}"/>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Row="1" Margin="0,4,0,0">
                    <!-- Dashboard -->
                    <Button x:Name="BtnDashboard" Style="{StaticResource SidebarMenuButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                        <Button.ToolTip>
                            <ToolTip Content="Dashboard" 
                                     Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16">
                                <Path Data="M13 3V11H21V3H13ZM19 9H15V5H19V9ZM3 13V21H11V13H3ZM9 19H5V5H19V19ZM3 3V11H11V3H3ZM9 9H5V5H9V9ZM13 13V21H21V13H13ZM19 19H15V15H19V19Z" 
                                      Fill="{StaticResource PrimaryBrush}"/>
                            </Viewbox>
                            <TextBlock Text="Dashboard" FontWeight="Bold" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </StackPanel>
                    </Button>

                    <!-- Threat Alerts -->
                    <Button x:Name="BtnThreatAlerts" Style="{StaticResource SidebarMenuButtonStyle}" 
                             Command="{Binding NavigateCommand}" CommandParameter="ThreatAlerts">
                        <Button.ToolTip>
                            <ToolTip Content="Threat Alerts"
                                     Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16">
                                <Path Data="M12 5.99L19.53 19H4.47L12 5.99ZM12 2L1 21H23L12 2ZM13 16H11V18H13V16ZM13 10H11V14H13V10Z" 
                                      Fill="#ff5252"/>
                            </Viewbox>
                            <TextBlock Text="Threat Alerts" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </StackPanel>
                    </Button>

                    <!-- Quarantine -->
                    <Button x:Name="BtnQuarantine" Style="{StaticResource SidebarMenuButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Quarantine">
                        <Button.ToolTip>
                            <ToolTip Content="Quarantine"
                                     Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16">
                                <Path Data="M12 4.14L10.09 5.09L5 7.64V12.22C5 15.63 7.82 18.77 12 20.31C16.18 18.77 19 15.63 19 12.22V7.64L13.91 5.09L12 4.14ZM12 2L20 6V12.22C20 16.59 16.63 20.45 12 22C7.37 20.45 4 16.59 4 12.22V6L12 2ZM11 11V7H13V11H11ZM11 13V15H13V13H11Z" 
                                      Fill="#ffa726"/>
                            </Viewbox>
                            <TextBlock Text="Quarantine" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </StackPanel>
                    </Button>

                    <!-- Process Monitor -->
                    <Button x:Name="BtnProcessMonitor" Style="{StaticResource SidebarMenuButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="ProcessMonitor">
                        <Button.ToolTip>
                            <ToolTip Content="Process Monitor"
                                     Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16">
                                <Path Data="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V5H19V19ZM7 11V17H9V11H7ZM11 6V17H13V6H11ZM15 14V17H17V14H15Z" 
                                      Fill="#b388ff"/>
                            </Viewbox>
                            <TextBlock Text="Process Monitor" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </StackPanel>
                    </Button>

                    <!-- File Activity -->
                    <Button x:Name="BtnFileActivity" Style="{StaticResource SidebarMenuButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="FileActivity">
                        <Button.ToolTip>
                            <ToolTip Content="File Activity"
                                     Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16">
                                <Path Data="M14 2H6C4.9 2 4.01 2.9 4.01 4L4 20C4 21.1 4.89 22 5.99 22H18C19.1 22 20 21.1 20 20V8L14 2ZM18 20H6V4H13V9H18V20ZM16 11V13H8V11H16ZM16 15V17H8V15H16Z" 
                                      Fill="#4fc3f7"/>
                            </Viewbox>
                            <TextBlock Text="File Activity" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </StackPanel>
                    </Button>

                    <!-- Reports -->
                    <Button x:Name="BtnReports" Style="{StaticResource SidebarMenuButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Reports">
                        <Button.ToolTip>
                            <ToolTip Content="Reports"
                                     Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16">
                                <Path Data="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V5H19V19ZM11 17V7H13V17H11ZM15 17V13H17V17H15ZM7 17V11H9V17H7Z" 
                                      Fill="{StaticResource SecondaryBrush}"/>
                            </Viewbox>
                            <TextBlock Text="Reports" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </StackPanel>
                    </Button>

                    <!-- Settings -->
                    <Button x:Name="BtnSettings" Style="{StaticResource SidebarMenuButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Settings">
                        <Button.ToolTip>
                            <ToolTip Content="Settings"
                                     Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="16" Height="16">
                                <Path Data="M19.43 12.98C19.48 12.66 19.5 12.34 19.5 12C19.5 11.66 19.48 11.34 19.43 11.02L21.54 9.37C21.73 9.22 21.78 8.95 21.66 8.73L19.66 5.27C19.54 5.05 19.27 4.96 19.05 5.05L16.56 6.05C16.04 5.65 15.48 5.32 14.87 5.07L14.49 2.42C14.46 2.18 14.25 2 14 2H10C9.75 2 9.54 2.18 9.51 2.42L9.13 5.07C8.52 5.32 7.96 5.66 7.44 6.05L4.95 5.05C4.73 4.96 4.46 5.05 4.34 5.27L2.34 8.73C2.21 8.95 2.27 9.22 2.46 9.37L4.57 11.02C4.52 11.34 4.5 11.66 4.5 12C4.5 12.34 4.52 12.66 4.57 12.98L2.46 14.63C2.27 14.78 2.21 15.05 2.34 15.27L4.34 18.73C4.46 18.95 4.73 19.04 4.95 18.95L7.44 17.95C7.96 18.35 8.52 18.68 9.13 18.93L9.51 21.58C9.54 21.82 9.75 22 10 22H14C14.25 22 14.46 21.82 14.49 21.58L14.87 18.93C15.48 18.68 16.04 18.35 16.56 17.95L19.05 18.95C19.27 19.04 19.54 18.95 19.66 18.73L21.66 15.27C21.78 15.05 21.73 14.78 21.54 14.63L19.43 12.98ZM12 15.5C10.07 15.5 8.5 13.93 8.5 12C8.5 10.07 10.07 8.5 12 8.5C13.93 8.5 15.5 10.07 15.5 12C15.5 13.93 13.93 15.5 12 15.5Z" 
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Viewbox>
                            <TextBlock Text="Settings" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Profile Area -->
                <Border Grid.Row="2" Margin="12,0,12,16" Padding="10" 
                        Background="#171b26" BorderBrush="#1affffff" BorderThickness="1" 
                        CornerRadius="10"
                        Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Avatar -->
                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" 
                                Background="#33adc6ff">
                            <TextBlock Text="NA" Foreground="{StaticResource PrimaryBrush}" 
                                       FontSize="10" FontWeight="Bold" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Text -->
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Node_Admin_01" Foreground="{StaticResource OnSurfaceBrush}" 
                                       FontWeight="Bold" FontSize="10" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="Level 4 Clearance" Foreground="{StaticResource OnSurfaceVariantBrush}" 
                                       FontSize="8" Opacity="0.7"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- CUSTOM TITLE BAR -->
        <Border Grid.Row="0" Grid.Column="1" Background="Transparent">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource CaptionButtonStyle}" Click="MinButton_Click">
                    <Path Data="M 0,0 L 10,0" Stroke="{StaticResource OnSurfaceBrush}" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource CaptionButtonStyle}" Click="MaxButton_Click">
                    <Path x:Name="MaxIcon" Stroke="{StaticResource OnSurfaceBrush}" StrokeThickness="1" Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Data" Value="M 0,0 L 10,0 L 10,10 L 0,10 Z"/> <!-- Maximize -->
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState, ElementName=RootWindow}" Value="Maximized">
                                        <Setter Property="Data" Value="M 2,4 L 10,4 L 10,10 L 2,10 Z M 4,4 L 4,2 L 12,2 L 12,8 L 10,8"/> <!-- Restore -->
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Button>
                <Button Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click">
                    <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="{StaticResource OnSurfaceBrush}" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- HEADER BAR -->
        <Border Grid.Row="1" Grid.Column="1" 
                Background="#0f131d" 
                BorderBrush="{StaticResource OutlineVariantBrush}" 
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHeaderTitle" Text="{Binding HeaderTitle}" Style="{StaticResource TextTitle}" 
                              Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                    <!-- System Live Badge -->
                    <Border x:Name="BrdHeaderStatus" Background="#1a4edea3" BorderBrush="#334edea3" BorderThickness="1" 
                            CornerRadius="4" Margin="12,0,0,0" Padding="6,2">
                        <TextBlock x:Name="TxtHeaderStatus" Text="{Binding HeaderStatus}" Foreground="#4edea3" 
                                   FontWeight="Bold" FontSize="9"/>
                    </Border>
                </StackPanel>
                
                <!-- Right side: Search and Icons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Search Box -->
                    <Border Background="{StaticResource SurfaceContainerHighestBrush}" 
                            CornerRadius="14" 
                            Width="210" Height="28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Search Icon -->
                            <Viewbox Grid.Column="0" Width="12" Height="12" Margin="10,0,5,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                      Fill="{StaticResource OutlineVariantBrush}"/>
                            </Viewbox>
                            <TextBox Grid.Column="1" Style="{StaticResource ModernTextBox}" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="{Binding SearchPlaceholder}" 
                                     FontSize="11" Margin="2,0,10,0"/>
                        </Grid>
                    </Border>
                    
                    <!-- Notification Icon -->
                    <Button x:Name="NotificationBtn" Style="{StaticResource IconButton}" Margin="16,0,0,0"
                            Command="{Binding ToggleNotificationsCommand}">
                        <Grid>
                            <Viewbox Width="16" Height="16" Margin="0,0,4,0">
                                <Path Data="M12 22C13.1 22 14 21.1 14 20H10C10 21.1 10.9 22 12 22ZM18 16V11C18 7.93 16.36 5.36 13.5 4.68V4C13.5 3.17 12.83 2.5 12 2.5C11.17 2.5 10.5 3.17 10.5 4V4.68C7.63 5.36 6 7.92 6 11V16L4 18V19H20V18L18 16ZM16 17H8V11C8 8.52 9.51 6.5 12 6.5C14.49 6.5 16 8.52 16 11V17Z" 
                                      Fill="#c2c6d6"/>
                            </Viewbox>
                            <!-- Red Dot Badge -->
                            <Ellipse Width="7" Height="7" Fill="{StaticResource TertiaryContainerBrush}" 
                                     Stroke="#0f131d" StrokeThickness="2"
                                     HorizontalAlignment="Right" VerticalAlignment="Top" 
                                     Margin="0,-2,2,0">
                                <Ellipse.Visibility>
                                    <Binding Path="UnreadNotificationsCount" Converter="{StaticResource TypeToBooleanConverter}">
                                        <Binding.ConverterParameter>
                                            <x:Type TypeName="x:Int32"/>
                                        </Binding.ConverterParameter>
                                    </Binding>
                                </Ellipse.Visibility>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UnreadNotificationsCount}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Button>
                    
                    <!-- Notification Flyout -->
                    <Popup IsOpen="{Binding IsNotificationFlyoutOpen}" StaysOpen="False" 
                           PlacementTarget="{Binding ElementName=NotificationBtn}" 
                           Placement="Bottom" HorizontalOffset="-240" VerticalOffset="10"
                           AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{StaticResource SurfaceContainerHighestBrush}" 
                                BorderBrush="{StaticResource OutlineVariantBrush}"
                                BorderThickness="1" CornerRadius="12" Width="300" MaxHeight="400">
                            <StackPanel Margin="16">
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Recent Security Events" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="13"/>
                                    <Button Content="Clear" Command="{Binding ClearNotificationsCommand}" HorizontalAlignment="Right"
                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource OutlineBrush}" FontSize="11" Cursor="Hand"/>
                                </Grid>
                                
                                <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Notifications}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0f131d" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Top" Margin="0,4,12,0"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="11" Foreground="#dfe2f1"/>
                                                            <TextBlock Text="{Binding Message}" FontSize="10" Foreground="#c2c6d6" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                            <TextBlock Text="{Binding Time}" FontSize="9" Foreground="#8c909f" Margin="0,4,0,0" Opacity="0.7"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <TextBlock Text="No active threats detected" HorizontalAlignment="Center" Margin="0,20" 
                                           Visibility="{Binding Notifications.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                           Foreground="{StaticResource OutlineBrush}" Opacity="0.5" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                    
                    <!-- User Icon -->
                    <Button Style="{StaticResource IconButton}" Margin="12,0,0,0">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 6C13.93 6 15.5 7.57 15.5 9.5C15.5 11.43 13.93 13 12 13C10.07 13 8.5 11.43 8.5 9.5C8.5 7.57 10.07 6 12 6ZM12 20C9.97 20 7.57 19.18 5.86 17.12C7.55 15.8 9.68 15 12 15C14.32 15 16.45 15.8 18.14 17.12C16.43 19.18 14.03 20 12 20Z" 
                                  Fill="#c2c6d6"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA (Placeholder for Views) -->
        <Border Grid.Row="2" Grid.Column="1" 
                Background="{StaticResource BackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- SERVICE OFFLINE BANNER -->
                <Border Grid.Row="0" Background="#33ff9800" BorderBrush="#66ff9800" BorderThickness="0,0,0,1" 
                        Padding="16,8" Visibility="{Binding IsServiceConnected, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#ff9800" Margin="0,0,12,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServiceConnected}" Value="False">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.8" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="SENTINEL SERVICE OFFLINE - PROTECTION DEGRADED" Foreground="#ff9800" 
                                   FontWeight="Black" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="(RE-INSTALL OR START SERVICE IN SETTINGS)" Foreground="#ff9800" 
                                   FontWeight="Bold" FontSize="9" VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.7"/>
                    </StackPanel>
                </Border>

                <!-- Content will be loaded here via navigation -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
            </Grid>
        </Border>

        <!-- BOTTOM STATUS BAR -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" 
                Background="#0a0e18" 
                BorderBrush="{StaticResource OutlineVariantBrush}" 
                BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="System Protected" Foreground="#4edea3" Style="{StaticResource TextSmall}" FontWeight="Bold" FontSize="9"/>
                    <TextBlock Text="|" Foreground="#c2c6d6" Style="{StaticResource TextSmall}" Margin="6,0" Opacity="0.4" FontSize="9"/>
                    <TextBlock Text="{Binding CpuUsageText}" Style="{StaticResource TextSmall}" FontSize="9"/>
                    <TextBlock Text="|" Foreground="#c2c6d6" Style="{StaticResource TextSmall}" Margin="6,0" Opacity="0.4" FontSize="9"/>
                    <TextBlock Text="{Binding MemoryUsageText}" Style="{StaticResource TextSmall}" FontSize="9"/>
                    <TextBlock Text="|" Foreground="#c2c6d6" Style="{StaticResource TextSmall}" Margin="6,0" Opacity="0.4" FontSize="9"/>
                    <TextBlock Text="Protection: ON" Foreground="#4edea3" Style="{StaticResource TextSmall}" FontSize="9"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Documentation" Style="{StaticResource TextSmall}" Opacity="0.5" FontSize="9"/>
                    <TextBlock Text="|" Style="{StaticResource TextSmall}" Margin="10,0" Opacity="0.2" FontSize="9"/>
                    <TextBlock Text="Support" Style="{StaticResource TextSmall}" Opacity="0.5" FontSize="9"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

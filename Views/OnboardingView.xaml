<UserControl x:Class="RansomGuard.Views.OnboardingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="Segoe UI">
    <Grid>
        <!-- Background Gradient Effect -->
        <Grid.OpacityMask>
            <RadialGradientBrush Center="0.2,0.3" RadiusX="0.5" RadiusY="0.5">
                <GradientStop Color="#0D4D8EFF" Offset="0"/>
                <GradientStop Color="Transparent" Offset="1"/>
            </RadialGradientBrush>
        </Grid.OpacityMask>
        <Rectangle Fill="{StaticResource PrimaryBrush}" Opacity="0.08"/>

        <!-- Onboarding Wizard Modal -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Width="896" Height="576" CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource SurfaceContainerHigh}" Opacity="0.6"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Branding -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" Padding="40" BorderThickness="0">
                    <Grid>
                        <StackPanel>
                            <!-- Logo & Title -->
                            <TextBlock Text="THE SENTINEL" FontSize="20" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,48"/>
                            
                            <TextBlock Text="Secure your digital perimeter." FontSize="28" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" LineHeight="36" Margin="0,0,0,16"/>
                            <TextBlock Text="Welcome to the core of your network's defense. Let's configure your sentinel nodes to match your business requirements." 
                                       FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.8" LineHeight="20" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Feature Badges -->
                        <StackPanel VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" 
                                      Fill="{StaticResource SecondaryBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="Real-time Encryption" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M3,3V5H5V3H3M7,3V5H9V3H7M11,3V5H13V3H11M15,3V5H17V3H15M19,3V5H21V3H19M3,7V9H5V7H3M7,7V9H9V7H7M11,7V9H13V7H11M15,7V9H17V7H15M19,7V9H21V7H19M3,11V13H5V11H3M7,11V13H9V11H7M11,11V13H13V11H11M15,11V13H17V11H15M19,11V13H21V11H19M3,15V17H5V15H3M7,15V17H9V15H7M11,15V17H13V15H11M15,15V17H17V15H15M19,15V17H21V15H19M3,19V21H5V19H3M7,19V21H9V19H7M11,19V21H13V19H11M15,19V21H17V19H15M19,19V21H21V19H19Z" 
                                      Fill="{StaticResource SecondaryBrush}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                                <TextBlock Text="AI Threat Analysis" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right Panel: Wizard Content -->
                <Grid Grid.Column="1" Background="{StaticResource SurfaceContainerBrush}" Opacity="0.4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Step Progress Indicator -->
                    <StackPanel Grid.Row="0" Margin="48,48,48,48">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Height="4" Background="{StaticResource PrimaryBrush}" CornerRadius="2"/>
                            <Border Grid.Column="2" Height="4" Background="{StaticResource SurfaceVariantBrush}" CornerRadius="2"/>
                            <Border Grid.Column="4" Height="4" Background="{StaticResource SurfaceVariantBrush}" CornerRadius="2"/>
                        </Grid>
                        <TextBlock Text="STEP 01 / 03" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,16,0,0" HorizontalAlignment="Right"/>
                    </StackPanel>

                    <!-- Main Content -->
                    <StackPanel Grid.Row="1" Margin="48,0,48,0">
                        <!-- Shield Icon -->
                        <Border Width="64" Height="64" Background="{StaticResource PrimaryBrush}" Opacity="0.1" CornerRadius="8" HorizontalAlignment="Left" Margin="0,0,0,24">
                            <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" 
                                  Fill="{StaticResource PrimaryBrush}" Width="32" Height="32" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Choose Protection Level" FontSize="24" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Select the operational posture for your security environment. You can modify these global rules later in Settings." 
                                   FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" LineHeight="20" TextWrapping="Wrap" Margin="0,0,0,40"/>

                        <!-- Protection Options -->
                        <StackPanel>
                            <!-- Standard Option (Recommended) -->
                            <Border BorderThickness="0" Padding="20" Margin="0,0,0,16" CornerRadius="8" Cursor="Hand">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource Primary}" Opacity="0.1"/>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Width="40" Height="40" Background="{StaticResource PrimaryBrush}" CornerRadius="8" VerticalAlignment="Top">
                                        <Path Data="M11.8,10.9C9.5,10.3 7.8,8.5 7.2,6.2C7.1,5.9 7.1,5.7 7.2,5.4C7.8,3.1 9.5,1.3 11.8,0.7C12.1,0.6 12.3,0.6 12.6,0.7C14.9,1.3 16.6,3.1 17.2,5.4C17.3,5.7 17.3,5.9 17.2,6.2C16.6,8.5 14.9,10.3 12.6,10.9C12.3,11 12.1,11 11.8,10.9Z" 
                                              Fill="{StaticResource OnPrimaryContainerBrush}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="Standard" FontSize="16" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                            <Border Background="{StaticResource SecondaryBrush}" Opacity="0.2" Padding="8,2" Margin="12,0,0,0" CornerRadius="4">
                                                <TextBlock Text="Recommended" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="Optimal balance between high security and workflow speed. Minimizes false positives for standard business operations." 
                                                   FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" LineHeight="18" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Selected Radio Button -->
                                    <Border Grid.Column="2" Width="20" Height="20" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2" CornerRadius="10" VerticalAlignment="Top">
                                        <Ellipse Width="10" Height="10" Fill="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Aggressive & Custom Options Grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Aggressive Option -->
                                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerHighBrush}" 
                                        Padding="20" CornerRadius="8" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource TertiaryContainerBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" Background="{StaticResource TertiaryContainerBrush}" Opacity="0.1" CornerRadius="8" Margin="0,0,12,0">
                                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1ZM12,10.99H19C18.47,15.11 15.72,18.78 12,19.93V11H5V5.3L12,2.19V10.99Z" 
                                                      Fill="{StaticResource TertiaryContainerBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Aggressive" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="Strict protocol enforcement. Ideal for high-risk data environments. May trigger more alerts." 
                                                   FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" LineHeight="16" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Custom Option -->
                                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerHighBrush}" 
                                        Padding="20" CornerRadius="8" Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="32" Height="32" Background="{StaticResource OnSurfaceVariantBrush}" Opacity="0.1" CornerRadius="8" Margin="0,0,12,0">
                                                <Path Data="M3,17V19H9V17H3M3,5V7H13V5H3M13,21V19H21V17H13V19H9V21H3M7,9V11H3V9H7M13,9V11H21V9H13M13,13V15H21V13H13M13,15V17H17V19H13V17M17,9V11H21V9H17M17,13V15H21V13H17Z" 
                                                      Fill="{StaticResource OnSurfaceVariantBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="Custom" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="Manually define node sensitivity, quarantine triggers, and alert thresholds for your specific stack." 
                                                   FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" LineHeight="16" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer Navigation -->
                    <Border Grid.Row="2" BorderThickness="0" Padding="48,32" Margin="48,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Back Button (Disabled) -->
                            <Button Grid.Column="0" HorizontalAlignment="Left" Padding="24,8" IsEnabled="False" Opacity="0.4" Style="{StaticResource SecondaryButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" 
                                          Fill="{StaticResource OnSurfaceVariantBrush}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                    <TextBlock Text="Back" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                </StackPanel>
                            </Button>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <!-- Skip Setup -->
                                <Button Style="{StaticResource TextButtonStyle}" Padding="24,12" Margin="0,0,24,0" HorizontalAlignment="Center">
                                    <TextBlock Text="SKIP SETUP" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                </Button>

                                <!-- Next Step Button -->
                                <Button Style="{StaticResource PrimaryButtonStyle}" Padding="32,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Next Step" FontSize="13" FontWeight="Bold" Foreground="{StaticResource OnPrimaryContainerBrush}" Margin="0,0,8,0"/>
                                        <Path Data="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" 
                                              Fill="{StaticResource OnPrimaryContainerBrush}" Width="14" Height="14" Stretch="Uniform"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>


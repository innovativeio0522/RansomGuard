<UserControl x:Class="RansomGuard.Views.QuarantineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            
            <!-- Storage Usage & Actions Bento Cluster -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Storage Usage Bento -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="12" Padding="24" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Quarantine Storage" FontSize="16" FontWeight="Black" 
                                          Foreground="{StaticResource OnSurfaceBrush}"/>
                                <TextBlock Text="Encrypted silo status and volume metrics" 
                                          FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,1,0,0" Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal">
                                <TextBlock Text="{Binding StorageUsedMb, StringFormat='{}{0:F1}'}" FontSize="20" FontWeight="Light" 
                                          Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text=" MB" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="2,0,4,2" VerticalAlignment="Bottom"/>
                                <TextBlock Text="/" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,4,2" VerticalAlignment="Bottom" Opacity="0.5"/>
                                <TextBlock Text="{Binding TotalStorageText}" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,2" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Height="6">
                            <ProgressBar Height="6" Value="{Binding StoragePercent}" Maximum="100"
                                        Background="{StaticResource SurfaceContainerHighestBrush}"
                                        BorderThickness="0">
                                <ProgressBar.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{StaticResource Primary}" Offset="0"/>
                                        <GradientStop Color="#4d8eff" Offset="1"/>
                                    </LinearGradientBrush>
                                </ProgressBar.Foreground>
                                <ProgressBar.Effect>
                                    <DropShadowEffect Color="{StaticResource Primary}" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                                </ProgressBar.Effect>
                            </ProgressBar>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                <Ellipse Width="4" Height="4" Fill="{StaticResource SecondaryBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="SYSTEM INTEGRITY: NOMINAL" FontSize="7" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="4" Height="4" Fill="{StaticResource TertiaryBrush}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="AUTO-PURGE: DISABLED" FontSize="7" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Action Hub Bento -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerHighBrush}" 
                        CornerRadius="12" Padding="20"
                        BorderBrush="#1affffff" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="BULK CONTROL" FontSize="9" FontWeight="Bold" Margin="0,0,0,16"
                                  Foreground="{StaticResource PrimaryBrush}"/>
                        
                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,0,10" Height="42" HorizontalContentAlignment="Stretch"
                                Command="{Binding ScanAllRepositoriesCommand}"
                                IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}">
                            <Grid>
                                <TextBlock Text="{Binding IsScanning, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Scanning...|Scan All Repositories'}" 
                                          FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Viewbox Width="16" Height="16" HorizontalAlignment="Right">
                                    <Path Data="M15.5,14L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5M9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14M12,10H10V12H9V10H7V9H9V7H10V9H12V10Z" 
                                          Fill="{StaticResource OnPrimaryContainerBrush}"/>
                                </Viewbox>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource NativeButton}" Height="42" Background="{StaticResource SurfaceContainerHighestBrush}" HorizontalContentAlignment="Stretch"
                                Command="{Binding ClearSafeFilesCommand}">
                            <Grid>
                                <TextBlock Text="Clear Safe Files" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Viewbox Width="16" Height="16" HorizontalAlignment="Right">
                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                          Fill="{StaticResource OnSurfaceVariantBrush}"/>
                                </Viewbox>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Quarantine Table -->
            <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" ClipToBounds="True">
                <StackPanel>
                    <!-- Table Header Bar -->
                    <Border Background="{StaticResource SurfaceVariantBrush}" 
                           Padding="24,16" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Opacity="0.8">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0">
                                    <Path Data="M10 18H14V16H10V18ZM3 6V8H21V6H3ZM6 13H18V11H6V13Z" 
                                          Fill="{StaticResource PrimaryBrush}"/>
                                </Viewbox>
                                <TextBlock Text="{Binding TotalItems, StringFormat='ISOLATED ENTITIES ({0})'}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="RESTORE SELECTED" Style="{StaticResource NativeButton}" 
                                       FontSize="10" FontWeight="Bold" Padding="16,8" Margin="0,0,8,0" Background="Transparent"
                                       BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="1"
                                       Command="{Binding RestoreSelectedCommand}"/>
                                <Button Content="PURGE SELECTED" Style="{StaticResource DangerButton}" 
                                       FontSize="10" FontWeight="Bold" Padding="16,8"
                                       Command="{Binding PurgeSelectedCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Table Columns Header -->
                    <Border Background="{StaticResource SurfaceContainerHighBrush}" Padding="24,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource NativeCheckBox}"
                                      IsChecked="{Binding IsAllSelected}"
                                      Command="{Binding ToggleSelectAllCommand}"/>
                            <TextBlock Grid.Column="1" Text="FILE NAME" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="ORIGINAL PATH" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="3" Text="DATE QUARANTINED" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="4" Text="THREAT TYPE" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="5" Text="RISK LEVEL" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="12,0,0,0"/>
                            <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding QuarantinedItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Padding="24,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0DFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid x:Name="RowGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource NativeCheckBox}"
                                                  IsChecked="{Binding IsSelected}"/>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                                                <Path Data="M18,8H17V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M12,17A2,2 0 1,1 14,15A2,2 0 0,1 12,17M15.1,8H8.9V6A3.1,3.1 0 0,1 12,2.9A3.1,3.1 0 0,1 15.1,6V8Z" 
                                                      Fill="{StaticResource TertiaryBrush}"/>
                                            </Viewbox>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource OnSurfaceBrush}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{Binding Path}" 
                                                  FontSize="11" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Opacity="0.7"/>
                                        
                                        <TextBlock Grid.Column="3" Text="{Binding Timestamp, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}" 
                                                  FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Opacity="0.8"/>
                                        
                                        <Border Grid.Column="4" Background="#1aff5451" BorderBrush="#33ff5451" BorderThickness="1"
                                               Padding="10,4" CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TertiaryBrush}" 
                                                      FontWeight="Bold" FontSize="9"/>
                                        </Border>

                                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Fill="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Severity}" Foreground="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" 
                                                      FontWeight="Black" FontSize="9"/>
                                        </StackPanel>

                                        <StackPanel x:Name="ActionPanel" Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Opacity="0.4">
                                            <Button Style="{StaticResource IconButton}" Margin="0,0,6,0" ToolTip="Restore"
                                                   Command="{Binding DataContext.RestoreFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}">
                                                <Viewbox Width="14" Height="14">
                                                    <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3Z" 
                                                          Fill="{StaticResource SecondaryBrush}"/>
                                                </Viewbox>
                                            </Button>
                                            <Button Style="{StaticResource IconButton}" ToolTip="Delete Permanently"
                                                   Command="{Binding DataContext.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}">
                                                <Viewbox Width="14" Height="14">
                                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                                          Fill="{StaticResource ErrorBrush}"/>
                                                </Viewbox>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Pagination / Footer -->
                    <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,1,0,0" Padding="24,12" Background="{StaticResource SurfaceContainerLowBrush}">
                        <Grid>
                            <TextBlock Text="{Binding PaginationStatus}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="PREVIOUS" Style="{StaticResource NativeButton}" 
                                       FontSize="10" FontWeight="Bold" Padding="12,6" Margin="0,0,16,0" 
                                       IsEnabled="{Binding CanNavigatePrevious}"
                                       Command="{Binding NavigatePreviousCommand}"/>
                                <Button Content="NEXT" Style="{StaticResource NativeButton}" 
                                       FontSize="10" FontWeight="Bold" Padding="12,6"
                                       IsEnabled="{Binding CanNavigateNext}"
                                       Command="{Binding NavigateNextCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Threat Intelligence Timeline (High-end Editorial UI) -->
            <Grid Margin="0,32,0,0">
                <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="32">
                    <StackPanel>
                        <TextBlock Text="CONTAINMENT INTELLIGENCE TIMELINE" FontSize="18" FontWeight="Black" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,32"/>
                        
                        <Grid>
                            <!-- Vertical Line -->
                            <Rectangle Fill="{StaticResource OutlineVariantBrush}" Width="2" HorizontalAlignment="Left" Margin="11,8,0,8" Opacity="0.3"/>
                            
                            <!-- Dynamic Timeline Events -->
                            <ItemsControl ItemsSource="{Binding TimelineEvents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,32">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Border Width="24" Height="24" Background="{StaticResource BackgroundBrush}" 
                                                   BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" 
                                                   BorderThickness="2" CornerRadius="12" VerticalAlignment="Top">
                                                <Ellipse Width="8" Height="8" 
                                                        Fill="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard RepeatBehavior="Forever">
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="10" FontWeight="Black" 
                                                              Foreground="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" 
                                                              VerticalAlignment="Center" Width="180">
                                                        <Run Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"/>
                                                        <Run Text=" — DETECTED"/>
                                                    </TextBlock>
                                                    <Border Background="{StaticResource SurfaceContainerBrush}" Padding="16" CornerRadius="8" 
                                                           BorderBrush="{Binding Severity, Converter={StaticResource SeverityToBrushConverter}}" 
                                                           BorderThickness="4,0,0,0" HorizontalAlignment="Stretch">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" 
                                                                      Foreground="{StaticResource OnSurfaceBrush}"/>
                                                            <TextBlock Text="{Binding Description}" 
                                                                      FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" 
                                                                      Margin="0,4,0,0" TextWrapping="Wrap" Opacity="0.7"/>
                                                            <TextBlock FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" 
                                                                      Margin="0,4,0,0" Opacity="0.6">
                                                                <Run Text="Target:"/>
                                                                <Run Text="{Binding Path}" FontWeight="SemiBold"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

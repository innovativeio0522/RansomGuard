<Window x:Class="RansomGuard.Views.ShieldUpAlert"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SHIELDS UP" WindowStyle="None" WindowState="Maximized" Topmost="True"
        Background="#1a0000" AllowsTransparency="True">
    
    <Grid>
        <Border BorderBrush="{StaticResource TertiaryBrush}" BorderThickness="4" Margin="20">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="HeaderLabel" Text="THREAT DETECTED" FontSize="72" FontWeight="Black" 
                           Foreground="{StaticResource TertiaryBrush}" HorizontalAlignment="Center">
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.5" AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>
                
                <TextBlock Text="URGENT: MASSIVE FILE MODIFICATION DETECTED" FontSize="24" FontWeight="Bold" 
                           Foreground="#ffb3ad" HorizontalAlignment="Center" Margin="0,20,0,10"/>

                <TextBlock Text="Was this you? Auto-mitigation starting in:" FontSize="18" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                
                <Grid Width="400" Margin="0,0,0,30">
                    <ProgressBar x:Name="CountdownProgress" Height="10" Maximum="5" Value="5" 
                                 Foreground="{StaticResource TertiaryBrush}" Background="#33ff5451"/>
                    <TextBlock x:Name="TimerText" Text="5s" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="White" FontWeight="Bold" Margin="0,15,0,0"/>
                </Grid>

                <Border Background="#33ff5451" CornerRadius="8" Padding="24" MaxWidth="600">
                    <StackPanel x:Name="ActionsList">
                        <TextBlock Text="PENDING ACTIONS (IF NO RESPONSE):" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <TextBlock x:Name="ProcessTerminatedText" Text="• Malicious process will be terminated" Foreground="White" Margin="8,0,0,4" Visibility="Collapsed"/>
                        <TextBlock x:Name="QuarantinedText" Text="• Source binary will be quarantined" Foreground="White" Margin="8,0,0,4" Visibility="Collapsed"/>
                        <TextBlock x:Name="NetworkDisabledText" Text="• Network adapters will be disabled" Foreground="White" Margin="8,0,0,4" Visibility="Collapsed"/>
                        <TextBlock x:Name="AlertLoggedText" Text="• Threat event logged to database" Foreground="White" Margin="8,0,0,4"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                    <Button x:Name="YesButton" Content="YES, IT WAS ME" Style="{StaticResource NativeButton}" 
                            Width="200" Height="50" Margin="0,0,20,0" Click="Yes_Click"/>
                    <Button x:Name="NoButton" Content="NO, BLOCK IT!" Style="{StaticResource DangerButton}" 
                            Width="200" Height="50" Click="No_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>

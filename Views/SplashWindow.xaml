<Window x:Class="RansomGuard.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Initializing RG Utility" Height="380" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    
    <Border CornerRadius="12" Background="{StaticResource SurfaceContainerLowestBrush}" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid>
            <!-- Background Decorative Element -->
            <Ellipse Width="300" Height="300" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{StaticResource PrimaryContainer}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Opacity>0.1</Ellipse.Opacity>
            </Ellipse>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Branding icon (Shield simulation) -->
                <Viewbox Width="80" Height="80" Margin="0,0,0,20">
                    <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" 
                          Fill="{StaticResource PrimaryBrush}"/>
                </Viewbox>
                
                <TextBlock Text="SYSTEM TOOLS" 
                           FontWeight="Black" 
                           FontSize="36" 
                           Foreground="{StaticResource OnSurfaceBrush}"
                           HorizontalAlignment="Center"/>
                
                <TextBlock Text="RESOURCE RG MODULE" 
                           FontWeight="SemiBold" 
                           FontSize="14" 
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" 
                           Margin="0,5,0,40"/>

                <ProgressBar x:Name="StartupProgress" 
                             Width="300" 
                             Height="4" 
                             IsIndeterminate="True" 
                             Foreground="{StaticResource PrimaryBrush}"
                             Background="{StaticResource SurfaceContainerHighestBrush}"
                             BorderThickness="0"/>
                             
                <TextBlock x:Name="StatusText"
                           Text="Initializing Sentinel Engine..." 
                           FontWeight="Medium" 
                           FontSize="12" 
                           Foreground="{StaticResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center" 
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>

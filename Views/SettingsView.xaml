<UserControl x:Class="RansomGuard.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource BackgroundBrush}"
             FontFamily="Segoe UI">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="48,32,48,48">
        <Grid HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Page Title -->
            <StackPanel Grid.Row="0" Margin="0,0,0,48">
                <TextBlock Text="Settings" FontSize="40" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,0"/>
                <TextBlock Text="Configure the node's behavioral parameters and protection protocols." FontSize="13" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Main Content Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Primary Settings -->
                <StackPanel Grid.Column="0" Margin="0,0,0,0">
                    <!-- General Protection Section -->
                    <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="32" Margin="0,0,0,32" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                                    <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                        <Path Data="M3,17V19H9V17H3M3,5V7H13V5H3M13,21V19H21V17H13V19H9V21H3M7,9V11H3V9H7M13,9V11H21V9H13M13,13V15H21V13H13M13,15V17H17V19H13V17M17,9V11H21V9H17M17,13V15H21V13H17Z" 
                                              Fill="{StaticResource PrimaryBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="General Protection" FontSize="20" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Real-time Protection Toggle -->
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Real-time protection" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                        <TextBlock Text="Intercept encryption attempts as they happen. Recommended for high-priority sentinel nodes." FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" 
                                                  Width="44" 
                                                  Height="22" 
                                                  IsChecked="{Binding IsRealTimeProtectionEnabled}" 
                                                  Style="{StaticResource ToggleSwitchStyle}" 
                                                  VerticalAlignment="Center" 
                                                  Margin="24,0,0,0"
                                                  AutomationProperties.Name="Real-time Protection Toggle"
                                                  AutomationProperties.HelpText="Enable or disable real-time protection to intercept encryption attempts"/>
                                </Grid>

                                <!-- Auto-quarantine Toggle -->
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Auto-quarantine" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                        <TextBlock Text="Immediately isolate detected malware. Prevents lateral movement across the network." FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" 
                                                  Width="44" 
                                                  Height="22" 
                                                  IsChecked="{Binding IsAutoQuarantineEnabled}" 
                                                  Style="{StaticResource ToggleSwitchStyle}" 
                                                  VerticalAlignment="Center" 
                                                  Margin="24,0,0,0"
                                                  AutomationProperties.Name="Auto-quarantine Toggle"
                                                  AutomationProperties.HelpText="Enable or disable automatic quarantine of detected malware"/>
                                </Grid>

                                <!-- Self-healing (Watchdog) Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Self-healing Protection" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                        <TextBlock Text="Ensures the protection engine and dashboard are always running. Restarts them automatically if they are terminated." FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" 
                                                  Width="44" 
                                                  Height="22" 
                                                  IsChecked="{Binding IsWatchdogEnabled}" 
                                                  Style="{StaticResource ToggleSwitchStyle}" 
                                                  VerticalAlignment="Center" 
                                                  Margin="24,0,0,0"
                                                  AutomationProperties.Name="Self-healing Toggle"
                                                  AutomationProperties.HelpText="Enable or disable the watchdog process that auto-restarts protection components"/>
                                </Grid>
                            </StackPanel>

                            <!-- Subtle Decoration -->
                            <Viewbox Grid.Column="1" Width="80" Height="80" Opacity="0.03" Margin="40,0,0,0" VerticalAlignment="Center">
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" Fill="{StaticResource OnSurfaceBrush}"/>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Protection Rules Section -->
                    <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="32" Margin="0,0,0,32" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,40">
                                    <Viewbox Width="24" Height="24" Margin="0,0,12,0">
                                        <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" 
                                              Fill="{StaticResource SecondaryBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="Protection Rules" FontSize="20" FontWeight="ExtraBold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Heuristic Sensitivity -->
                                <StackPanel Margin="0,0,0,40">
                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Heuristic Sensitivity" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                            <TextBlock Text="Define the threshold for behavioral anomaly detection." FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{StaticResource SurfaceContainerHighestBrush}" Padding="12,4" CornerRadius="4" VerticalAlignment="Top" HorizontalAlignment="Right" MinWidth="80">
                                            <TextBlock Text="{Binding SensitivityLabel}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <!-- Slider -->
                                    <StackPanel Margin="8,0,8,0">
                                        <Slider Minimum="1" Maximum="4" Value="{Binding SensitivityLevel, UpdateSourceTrigger=PropertyChanged}" TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="True" 
                                                Style="{StaticResource CustomSliderStyle}" Margin="0,0,0,16"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="LOW" FontSize="10" FontWeight="Black" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SensitivityLevel}" Value="1">
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="MEDIUM" FontSize="10" FontWeight="Black" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SensitivityLevel}" Value="2">
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" Text="HIGH" FontSize="10" FontWeight="Black" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SensitivityLevel}" Value="3">
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="3" Text="PARANOID" FontSize="10" FontWeight="Black" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource OnSurfaceVariantBrush}"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SensitivityLevel}" Value="4">
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TertiaryContainerBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Decorative Grid -->
                            <Viewbox Grid.Column="1" Width="120" Height="120" Opacity="0.05" Margin="40,0,-40,0" VerticalAlignment="Center">
                                <Path Data="M0,0 H100 M0,20 H100 M0,40 H100 M0,60 H100 M0,80 H100 M0,100 H100 M0,0 V100 M20,0 V100 M40,0 V100 M60,0 V100 M80,0 V100 M100,0 V100" 
                                      Stroke="{StaticResource OnSurfaceBrush}" StrokeThickness="0.5"/>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Exclusions Section -->
                    <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="32" CornerRadius="12">
                        <StackPanel>
                            <Grid Margin="0,0,0,32">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                                        <Path Data="M19,15V13H17V15H15V17H17V19H19V17H21V15H19M11,17C11,13.14 14.14,10 18,10C18.69,10 19.35,10.1 19.96,10.3C19.74,8.96 18.94,7.76 17.78,7.03L12,3.5L3.5,8.13V17.5C3.5,18.05 3.95,18.5 4.5,18.5H11.08C11.03,18 11,17.5 11,17M12,11.5L7,11.5V10.5L12,10.5V11.5Z" 
                                              Fill="{StaticResource OnSurfaceVariantBrush}" Opacity="0.5"/>
                                    </Viewbox>
                                    <TextBlock Text="Protected Folders" FontSize="18" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Padding="16,8" 
                                        Background="{StaticResource SurfaceContainerHighBrush}"
                                        Command="{Binding AddPathCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                            <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="{StaticResource PrimaryBrush}"/>
                                        </Viewbox>
                                        <TextBlock Text="Add Folder" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="Only files within these folders are actively monitored. All other system locations are excluded by default." FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.5" Margin="0,-16,0,16"/>

                            <!-- Protected Directory Items -->
                            <ItemsControl ItemsSource="{Binding MonitoredPaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SurfaceContainerHighBrush}" Padding="16,12" Margin="0,0,0,8" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <Viewbox Grid.Column="0" Width="16" Height="16" Margin="0,0,16,0" Opacity="0.5">
                                                    <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Fill="{StaticResource OnSurfaceBrush}"/>
                                                </Viewbox>
                                                
                                                <TextBlock Grid.Column="1" Text="{Binding Path}" FontSize="12" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                
                                                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                                    <Border Background="{StaticResource SurfaceContainerHighestBrush}" Padding="8,4" CornerRadius="4" HorizontalAlignment="Right">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStandard}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="STANDARD" FontSize="9" FontWeight="Black" Foreground="{StaticResource SecondaryBrush}" Opacity="0.8"/>
                                                    </Border>

                                                    <Button Command="{Binding DataContext.RemovePathCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Remove this folder from protection"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsStandard}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Viewbox Width="14" Height="14" Opacity="0.4">
                                                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{StaticResource OnSurfaceBrush}"/>
                                                        </Viewbox>
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- System Maintenance Section -->
                    <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="32" Margin="0,32,0,0" CornerRadius="12" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,2,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                                        <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11.03L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.49,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.51,2.42L9.13,5.07C8.52,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.03C4.52,11.34 4.5,11.67 4.5,12C4.5,12.33 4.52,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.33,15.05 2.46,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.52,18.68 9.13,18.93L9.51,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.49,21.58L14.87,18.93C15.48,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                                              Fill="{StaticResource PrimaryBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="System Maintenance" FontSize="18" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Manage the low-level background protection service. Professional-grade defense requires the background service to be active." FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,16"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" 
                                    Command="{Binding InstallServiceCommand}"
                                    Width="200" Padding="0,12" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="14" Height="14" Margin="0,0,12,0">
                                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="White"/>
                                    </Viewbox>
                                    <TextBlock Text="INSTALL SERVICE" FontWeight="Black" FontSize="11"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Right Column: Status & Info -->
                <StackPanel Grid.Column="2">
                    <!-- License Status Card -->
                    <Border Background="{StaticResource SurfaceContainerHighBrush}" Padding="24" Margin="0,0,0,32" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="PRODUCT LICENSE" FontSize="10" FontWeight="Black" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16" Opacity="0.8"/>
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Business Edition" FontSize="20" FontWeight="Black" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                <Ellipse Grid.Column="1" Width="8" Height="8" Fill="{StaticResource SecondaryBrush}" VerticalAlignment="Center">
                                    <Ellipse.Effect>
                                        <BlurEffect Radius="8"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>

                            <StackPanel Margin="0,0,0,32">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Status" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7"/>
                                    <TextBlock Text="Active" FontSize="12" Foreground="{StaticResource SecondaryBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Renew Date" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="1" Text="12-NOV-2025" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" FontFamily="Consolas"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Node ID" FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    <TextBlock Grid.Column="1" Text="TS-8849-PX" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" FontFamily="Consolas"/>
                                </Grid>
                            </StackPanel>

                            <Button Style="{StaticResource PrimaryButtonStyle}" Content="MANAGE SUBSCRIPTION" Padding="0,14" HorizontalAlignment="Stretch" FontSize="11" FontWeight="Black"/>
                        </StackPanel>
                    </Border>

                    <!-- Quick Help / Documentation -->
                    <Border Background="{StaticResource SurfaceContainerLowBrush}" Padding="24" CornerRadius="12" Margin="0,0,0,32" Opacity="0.9">
                        <StackPanel>
                            <TextBlock Text="Documentation" FontSize="14" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,0,20"/>
                            
                            <StackPanel>
                                <Button Style="{StaticResource TextButtonStyle}" Padding="0,8" Margin="0,0,0,4" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="16" Height="16" Margin="0,0,12,0">
                                            <Path Data="M208,32H72A32,32,0,0,0,40,64V192a32,32,0,0,0,32,32H208a8,8,0,0,0,8-8V40A8,8,0,0,0,208,32ZM160,48V160H80a8,8,0,0,1,0-16h72V48ZM72,208a16,16,0,0,1-16-16V64a16,16,0,0,1,16-16H144V192a8,8,0,0,0,8,8H200v8Z" Fill="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7"/>
                                        </Viewbox>
                                        <TextBlock Text="Deployment Guide" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button Style="{StaticResource TextButtonStyle}" Padding="0,8" Margin="0,0,0,4" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="16" Height="16" Margin="0,0,12,0">
                                            <Path Data="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216ZM128,168a8,8,0,1,1-8,8A8,8,0,0,1,128,168Zm4.8-100.8a48.06,48.06,0,0,0-57.6,0,8,8,0,1,0,9.6,12.8,32,32,0,1,1,43.2,0,8,8,0,0,0-4,13.84V144a8,8,0,0,0,16,0V113.6a47.94,47.94,0,0,0,36-46.4,47.88,47.88,0,0,0-43.2-48Z" Fill="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7"/>
                                        </Viewbox>
                                        <TextBlock Text="Sensitivity Tuning FAQ" FontSize="12" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                    </StackPanel>
                                </Button>


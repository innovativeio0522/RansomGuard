<UserControl x:Class="RansomGuard.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16">
            
            <!-- Stats Row (4 cards) -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Files Monitored -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" 
                              Fill="{StaticResource OnSurfaceBrush}" Opacity="0.05" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Width="48" Margin="0,8,8,0"/>
                        <StackPanel Margin="16">
                            <TextBlock Text="FILES MONITORED" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="{Binding FilesMonitoredCount}" FontSize="28" FontWeight="Black" 
                                      Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                    <Path Data="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" 
                                          Fill="{StaticResource SecondaryBrush}"/>
                                </Viewbox>
                                <TextBlock Text="{Binding FilesPerHourText}" Style="{StaticResource TextStatusSafe}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Threats Blocked -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" 
                        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,2" ClipToBounds="True">
                    <Grid>
                        <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" 
                              Fill="{StaticResource OnSurfaceBrush}" Opacity="0.05" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Width="48" Margin="0,8,8,0"/>
                        <StackPanel Margin="16">
                            <TextBlock Text="THREATS BLOCKED" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="{Binding ThreatsBlockedCount}" FontSize="28" FontWeight="Black" 
                                      Foreground="{StaticResource PrimaryBrush}" Margin="0,8,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                    <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" 
                                          Fill="{StaticResource OnSurfaceVariantBrush}"/>
                                </Viewbox>
                                <TextBlock Text="SINCE LAST REBOOT" Style="{StaticResource TextSmall}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Active Processes -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <Path Data="M15 9H9v6h6V9zm-2 4h-2v-2h2v2zm8-2V9h-2V7c0-1.1-.9-2-2-2h-2V3h-2v2h-2V3H9v2H7c-1.1 0-2 .9-2 2v2H3v2h2v2H3v2h2v2c0 1.1.9 2 2 2h2v2h2v-2h2v2h2v-2h2c1.1 0 2-.9 2-2v-2h2v-2h-2v-2h2zm-4 6H7V7h14v10z" 
                              Fill="{StaticResource OnSurfaceBrush}" Opacity="0.05" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Width="48" Margin="0,8,8,0"/>
                        <StackPanel Margin="16">
                            <TextBlock Text="SYSTEM CPU LOAD" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="{Binding CpuUsagePercent, StringFormat='{}{0:F1}%'}" FontSize="28" FontWeight="Black" 
                                      Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                            <ProgressBar Height="4" Value="{Binding CpuUsagePercent}" Maximum="100" Margin="0,12,0,0"
                                        Background="{StaticResource SurfaceContainerHighestBrush}"
                                        Foreground="{StaticResource SecondaryBrush}"
                                        BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Last Scan -->
                <Border Grid.Column="6" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <Path Data="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79 s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 2.5-.98 4.81-2.73 6.56-3.52 3.49-9.21 3.49-12.73 0-3.52-3.5-3.52-9.18 0-12.68 3.52-3.5 9.21-3.5 12.73 0l2.84-2.92V10.12z" 
                              Fill="{StaticResource OnSurfaceBrush}" Opacity="0.05" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Width="48" Margin="0,8,8,0"/>
                        <StackPanel Margin="16">
                            <TextBlock Text="LAST SCAN" Style="{StaticResource TextLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Height="40">
                                <TextBlock Text="{Binding LastScanText}" FontSize="20" FontWeight="Black" 
                                          Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid Margin="0,12,0,0">
                                <TextBlock Text="SYSTEM SECURED" Style="{StaticResource TextStatusSafe}" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Button Content="{Binding RescanButtonText}" Style="{StaticResource PrimaryButton}" 
                                       Command="{Binding RescanCommand}"
                                       HorizontalAlignment="Right" Padding="12,6"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Active Defense Shields -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Honey Pot Trap -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Margin="0,0,12,0"
                                 Fill="{Binding IsHoneyPotActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#4edea3" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <StackPanel>
                            <TextBlock Text="HONEY POT TRIPWIRE" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="{Binding IsHoneyPotActive, Converter={StaticResource BooleanToStatusConverter}, ConverterParameter='ARMED;DISARMED'}" 
                                      FontSize="14" FontWeight="Bold" Foreground="{Binding IsHoneyPotActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- VSS Shield -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Margin="0,0,12,0"
                                 Fill="{Binding IsVssShieldActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#4edea3" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <StackPanel>
                            <TextBlock Text="VSS SHADOW PROTECTION" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="{Binding IsVssShieldActive, Converter={StaticResource BooleanToStatusConverter}, ConverterParameter='LOCKED;UNPROTECTED'}" 
                                      FontSize="14" FontWeight="Bold" Foreground="{Binding IsVssShieldActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Panic Mode -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="12" Height="12" Margin="0,0,12,0"
                                 Fill="{Binding IsPanicModeEngaged, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=TertiaryBrush}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPanicModeEngaged}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <StackPanel>
                            <TextBlock Text="EMERGENCY LOCKDOWN" Style="{StaticResource TextLabel}"/>
                            <TextBlock Text="{Binding IsPanicModeEngaged, Converter={StaticResource BooleanToStatusConverter}, ConverterParameter='ENGAGED;STANDBY'}" 
                                      FontSize="14" FontWeight="Bold" Foreground="{Binding IsPanicModeEngaged, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=TertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Three Panel Layout -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Real-time File Activity -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8">
                    <StackPanel>
                        <Border Background="{StaticResource SurfaceContainerHighestBrush}" 
                               Padding="16" CornerRadius="8,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SecondaryBrush}" 
                                        Margin="0,0,8,0">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                                   From="1" To="0.3" Duration="0:0:1" 
                                                                   AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="REAL-TIME FILE ACTIVITY" Style="{StaticResource TextLabel}"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding RecentActivities}" Margin="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{Binding IsSuspicious, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}" 
                                            BorderThickness="2,0,0,0" 
                                            Background="{StaticResource SurfaceContainerBrush}" 
                                            Padding="12" Margin="0,0,0,8" CornerRadius="0,4,4,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FilePath}" 
                                                      Style="{StaticResource TextBody}" FontSize="11"/>
                                            <TextBlock Text="{Binding Action, StringFormat='{}{0} ACTION'}" 
                                                      Style="{StaticResource TextSmall}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- CENTER: Threat Risk Gauge -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" Padding="24">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Gauge -->
                        <Grid Width="200" Height="200" HorizontalAlignment="Center">
                            <Viewbox Width="200" Height="200">
                                <Grid>
                                    <!-- Background Ring -->
                                    <Ellipse Width="288" Height="288" Stroke="{StaticResource SurfaceContainerHighestBrush}" 
                                            StrokeThickness="12" Fill="Transparent"/>
                                    <!-- Progress Ring - arc driven by ThreatRingOffset -->
                                    <Ellipse Width="288" Height="288" Stroke="{StaticResource SecondaryBrush}" 
                                            StrokeThickness="12" Fill="Transparent"
                                            StrokeDashArray="283" StrokeDashOffset="{Binding ThreatRingOffset}"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#4edea3" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                                        </Ellipse.Effect>
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <!-- Decorative outer tick ring -->
                                    <Ellipse Width="268" Height="268" Stroke="{StaticResource OutlineVariantBrush}" StrokeThickness="1" Fill="Transparent" Opacity="0.18" StrokeDashArray="2,14" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform></Ellipse>
                                    <!-- Center Text -->
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="THREAT RISK SCORE" Style="{StaticResource TextLabel}" FontSize="18"
                                                  HorizontalAlignment="Center" Margin="0,13,0,-12"/>
                                        <TextBlock Text="{Binding ThreatRiskScore}" FontSize="96" FontWeight="Black" 
                                                  Foreground="{StaticResource OnSurfaceBrush}" 
                                                  HorizontalAlignment="Center" LineHeight="1">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="White" Opacity="0.1"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <Border Background="#1a4edea3" 
                                               Padding="16,6" CornerRadius="16" Margin="0,16,0,0" HorizontalAlignment="Center">
                                            <TextBlock Text="SECURED" Foreground="#4edea3" 
                                                      FontWeight="Bold" FontSize="10"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Viewbox>
                        </Grid>

                        <!-- Status Indicators -->
                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="HEURISTICS" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding HeuristicsStatus}" 
                                          Foreground="{Binding HeuristicsStatus, Converter={StaticResource StatusToBrushConverter}}"
                                          FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.5" Duration="0:0:2"
                                                                     AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <SineEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>

                            <Rectangle Grid.Column="1" HorizontalAlignment="Center"
                                      Width="1" Height="40" VerticalAlignment="Center" 
                                      Fill="{StaticResource OutlineVariantBrush}" Opacity="0.15"/>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="BEHAVIORAL" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding BehavioralStatus}" 
                                          Foreground="{Binding BehavioralStatus, Converter={StaticResource StatusToBrushConverter}}"
                                          FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.5" Duration="0:0:2.5"
                                                                     AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <SineEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>

                            <Rectangle Grid.Column="3" HorizontalAlignment="Center"
                                      Width="1" Height="40" VerticalAlignment="Center"
                                      Fill="{StaticResource OutlineVariantBrush}" Opacity="0.15"/>

                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="ENTROPY" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding EntropyScoreText, StringFormat='{}{0} H/b'}" FontSize="18" FontWeight="Bold" 
                                          Foreground="{StaticResource SecondaryBrush}" 
                                          HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RIGHT: Active Alerts -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8">
                    <StackPanel>
                        <Border Background="{StaticResource SurfaceContainerHighestBrush}" 
                               Padding="16" CornerRadius="8,8,0,0">
                            <Grid>
                                <TextBlock Text="ACTIVE ALERTS" Style="{StaticResource TextLabel}"/>
                                <Border Background="{StaticResource TertiaryContainerBrush}" 
                                       Padding="8,4" CornerRadius="4" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding NewAlertsText}" Foreground="{StaticResource OnTertiaryContainerBrush}" 
                                              FontWeight="Bold" FontSize="10"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding ActiveAlerts}" Margin="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceContainerBrush}" 
                                           Margin="0,0,0,12" CornerRadius="8" ClipToBounds="True">
                                        <Grid>
                                            <StackPanel Margin="16">
                                                <Grid Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Viewbox Width="16" Height="16" Margin="0,0,8,0">
                                                            <Path Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" 
                                                                  Fill="{StaticResource TertiaryBrush}"/>
                                                        </Viewbox>
                                                        <TextBlock Text="{Binding Name}" 
                                                                  Style="{StaticResource TextBody}" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding Path, StringFormat='Target: {0}'}" 
                                                          Style="{StaticResource TextSmall}" TextWrapping="Wrap"/>
                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Content="IGNORE" Grid.Column="0" 
                                                           Style="{StaticResource NativeButton}" Padding="8,6"
                                                           Command="{Binding DataContext.IgnoreAlertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"/>
                                                    <Button Content="QUARANTINE" Grid.Column="2" 
                                                           Style="{StaticResource DangerButton}" Padding="8,6"
                                                           Command="{Binding DataContext.QuarantineAlertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"/>
                                                </Grid>
                                            </StackPanel>
                                            
                                            <Border Background="{StaticResource TertiaryBrush}" Opacity="0.1" CornerRadius="0,0,0,8" 
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Severity}" Foreground="Transparent" 
                                                           FontWeight="Black" FontSize="9" Padding="12,4"/>
                                            </Border>
                                            <TextBlock Text="{Binding Severity}" Foreground="{StaticResource TertiaryBrush}" 
                                                       FontWeight="Black" FontSize="9" Padding="12,4" 
                                                       HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="VIEW ALL INCIDENT LOGS" Style="{StaticResource NativeButton}" 
                               Command="{Binding ViewAllLogsCommand}"
                               Margin="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- System Architecture Visualization (Decorative Section) -->
            <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" ClipToBounds="True" MinHeight="200">
                <Grid>
                    <!-- Simulated Background Map / Data Flow placeholder -->
                    <Path Data="M0,0 L100,100" Stretch="Fill" Stroke="{StaticResource SurfaceContainerHighestBrush}" Opacity="0.1"/>
                    
                    <Grid Margin="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Neural Protection Engine " FontSize="20" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                <TextBlock Text="v4.2.0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="The Sentinel is currently employing deep-packet inspection and behavioral heuristics across all active network nodes. Protection is optimized for the current threat landscape." 
                                       Style="{StaticResource TextSmall}" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Left" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            
                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                <Border Background="{StaticResource SurfaceContainerHighestBrush}" Padding="12,6" CornerRadius="4" Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                            <Path Data="M19 15v4H5v-4h14m1-2H4c-.55 0-1 .45-1 1v6c0 .55.45 1 1 1h16c.55 0 1-.45 1-1v-6c0-.55-.45-1-1-1zM7 18.5c-.82 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM19 5v4H5V5h14m1-2H4c-.55 0-1 .45-1 1v6c0 .55.45 1 1 1h16c.55 0 1-.45 1-1V4c0-.55-.45-1-1-1zM7 8.5c-.82 0-1.5-.68-1.5-1.5S6.18 5.5 7 5.5s1.5.68 1.5 1.5S7.83 8.5 7 8.5z" Fill="{StaticResource SecondaryBrush}"/>
                                        </Viewbox>
                                        <TextBlock Text="{Binding ActiveEndpoints, StringFormat='{}{0} ENDPOINTS ACTIVE'}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource SurfaceContainerHighestBrush}" Padding="12,6" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                            <Path Data="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM10 17l-3.5-3.5 1.41-1.41L10 14.17 15.18 9l1.41 1.41L10 17z" Fill="{StaticResource PrimaryBrush}"/>
                                        </Viewbox>
                                        <TextBlock Text="RAM USAGE" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource OnSurfaceBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding RamUsageText}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource SecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="NETWORK LATENCY" Style="{StaticResource TextLabel}" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding NetworkLatency}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" HorizontalAlignment="Right" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="ENCRYPTION LEVEL" Style="{StaticResource TextLabel}" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding EncryptionLevel}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>

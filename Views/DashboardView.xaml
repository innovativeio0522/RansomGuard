<UserControl x:Class="RansomGuard.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
            
        <!-- Stats Row (4 cards) -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Files Monitored -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" 
                              Fill="{StaticResource OnSurfaceBrush}" Opacity="0.05" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Margin="0,4,4,0"/>
                        <StackPanel Margin="10,8">
                            <TextBlock Text="FOLDERS PROTECTED" Style="{StaticResource TextLabel}" FontSize="8"/>
                            <TextBlock Text="{Binding FilesMonitoredCount}" FontSize="20" FontWeight="Black" 
                                      Foreground="{StaticResource OnSurfaceBrush}" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Viewbox Width="9" Height="9" Margin="0,0,3,0">
                                    <Path Data="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z" 
                                          Fill="{StaticResource SecondaryBrush}"/>
                                </Viewbox>
                                <TextBlock Text="{Binding FilesPerHourText}" Style="{StaticResource TextStatusSafe}" FontSize="8"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Threats Blocked -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" 
                        BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="0,0,0,2" ClipToBounds="True">
                    <Grid>
                        <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" 
                              Fill="{StaticResource OnSurfaceBrush}" Opacity="0.05" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Margin="0,4,4,0"/>
                        <StackPanel Margin="10,8">
                            <TextBlock Text="THREATS BLOCKED" Style="{StaticResource TextLabel}" FontSize="8"/>
                            <TextBlock Text="{Binding ThreatsBlockedCount}" FontSize="20" FontWeight="Black" 
                                      Foreground="{StaticResource PrimaryBrush}" Margin="0,4,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Viewbox Width="9" Height="9" Margin="0,0,3,0">
                                    <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" 
                                          Fill="{StaticResource OnSurfaceVariantBrush}"/>
                                </Viewbox>
                                <TextBlock Text="SINCE LAST REBOOT" Style="{StaticResource TextSmall}" FontSize="8"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Last Scan -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" ClipToBounds="True">
                    <Grid>
                        <Path Data="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79 s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 2.5-.98 4.81-2.73 6.56-3.52 3.49-9.21 3.49-12.73 0-3.52-3.5-3.52-9.18 0-12.68 3.52-3.5 9.21-3.5 12.73 0l2.84-2.92V10.12z" 
                              Fill="{StaticResource OnSurfaceBrush}" Opacity="0.05" Stretch="Uniform"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Margin="0,4,4,0"/>
                        <StackPanel Margin="10,8">
                            <TextBlock Text="LAST SCAN" Style="{StaticResource TextLabel}" FontSize="8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Height="26">
                                <TextBlock Text="{Binding LastScanText}" FontSize="16" FontWeight="Black" 
                                          Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="SYSTEM SECURED" Style="{StaticResource TextStatusSafe}" FontWeight="Bold" VerticalAlignment="Center" FontSize="8"/>
                                <Button Content="{Binding RescanButtonText}" Style="{StaticResource PrimaryButton}" 
                                       Command="{Binding RescanCommand}"
                                       HorizontalAlignment="Right" Padding="8,4" FontSize="9"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- Active Defense Shields -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Honey Pot Trap -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="10,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                 Fill="{Binding IsHoneyPotActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#4edea3" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <StackPanel>
                            <TextBlock Text="HONEY POT TRIPWIRE" Style="{StaticResource TextLabel}" FontSize="9"/>
                            <TextBlock Text="{Binding IsHoneyPotActive, Converter={StaticResource BooleanToStatusConverter}, ConverterParameter='ARMED;DISARMED'}" 
                                      FontSize="12" FontWeight="Bold" Foreground="{Binding IsHoneyPotActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- VSS Shield -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="10,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                 Fill="{Binding IsVssShieldActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#4edea3" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <StackPanel>
                            <TextBlock Text="VSS SHADOW PROTECTION" Style="{StaticResource TextLabel}" FontSize="9"/>
                            <TextBlock Text="{Binding IsVssShieldActive, Converter={StaticResource BooleanToStatusConverter}, ConverterParameter='LOCKED;UNPROTECTED'}" 
                                      FontSize="12" FontWeight="Bold" Foreground="{Binding IsVssShieldActive, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Panic Mode -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="10,8">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                 Fill="{Binding IsPanicModeEngaged, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=TertiaryBrush}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPanicModeEngaged}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.5" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <StackPanel>
                            <TextBlock Text="EMERGENCY LOCKDOWN" Style="{StaticResource TextLabel}" FontSize="9"/>
                            <TextBlock Text="{Binding IsPanicModeEngaged, Converter={StaticResource BooleanToStatusConverter}, ConverterParameter='ENGAGED;STANDBY'}" 
                                      FontSize="12" FontWeight="Bold" Foreground="{Binding IsPanicModeEngaged, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=TertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Three Panel Layout -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Real-time File Activity -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceContainerHighestBrush}" 
                               Padding="12,8" CornerRadius="8,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SecondaryBrush}" 
                                        Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                                                                   From="1" To="0.3" Duration="0:0:1" 
                                                                   AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="REAL-TIME FILE ACTIVITY" Style="{StaticResource TextLabel}" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                                     HorizontalScrollBarVisibility="Disabled" 
                                     Padding="8">
                            <Grid>
                                <!-- Empty State -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,48,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RecentActivities.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Viewbox Width="32" Height="32" Opacity="0.2" Margin="0,0,0,12">
                                        <Path Data="M18 7c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V7zm-2 10H4V7h12v10zm2-7l4-4v12l-4-4v-4z" Fill="{StaticResource OnSurfaceBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="No recent activity detected" Style="{StaticResource TextSmall}" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" Opacity="0.5"/>
                                    <TextBlock Text="Monitoring system events..." Style="{StaticResource TextLabel}" FontSize="8" HorizontalAlignment="Center" Opacity="0.3" Margin="0,4,0,0"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding RecentActivities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{Binding IsSuspicious, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=SecondaryBrush}" 
                                                    BorderThickness="2,0,0,0" 
                                                    Background="{StaticResource SurfaceContainerBrush}" 
                                                    Padding="8,6" Margin="0,0,0,4" CornerRadius="0,4,4,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="{Binding FilePath}" 
                                                              Style="{StaticResource TextBody}" 
                                                              FontSize="10" 
                                                              TextTrimming="CharacterEllipsis"
                                                              ToolTip="{Binding FilePath}"/>
                                                    <TextBlock Grid.Row="1" Text="{Binding Action, StringFormat='{}{0} ACTION'}" 
                                                              Style="{StaticResource TextSmall}" 
                                                              FontSize="9"
                                                              Margin="0,2,0,0"
                                                              Opacity="0.7"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- CENTER: Threat Risk Gauge -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8" Padding="12">
                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" Margin="12">
                        <!-- Gauge -->
                        <Grid Width="200" Height="200" HorizontalAlignment="Center">
                            <Viewbox Width="200" Height="200">
                                <Grid>
                                    <!-- Background Ring -->
                                    <Ellipse Width="288" Height="288" Stroke="{StaticResource SurfaceContainerHighestBrush}" 
                                            StrokeThickness="12" Fill="Transparent"/>
                                    <!-- Progress Ring - arc driven by ThreatRingOffset -->
                                    <Ellipse Width="288" Height="288" Stroke="{StaticResource SecondaryBrush}" 
                                            StrokeThickness="12" Fill="Transparent"
                                            StrokeDashArray="283" StrokeDashOffset="{Binding ThreatRingOffset}"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#4edea3" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
                                        </Ellipse.Effect>
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="-90"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <!-- Decorative outer tick ring -->
                                    <Ellipse Width="268" Height="268" Stroke="{StaticResource OutlineVariantBrush}" StrokeThickness="1" Fill="Transparent" Opacity="0.18" StrokeDashArray="2,14" RenderTransformOrigin="0.5,0.5"><Ellipse.RenderTransform><RotateTransform Angle="-90"/></Ellipse.RenderTransform></Ellipse>
                                    <!-- Center Text -->
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="THREAT RISK SCORE" Style="{StaticResource TextLabel}" FontSize="18"
                                                  HorizontalAlignment="Center" Margin="0,13,0,-12"/>
                                        <TextBlock Text="{Binding ThreatRiskScore}" FontSize="96" FontWeight="Black" 
                                                  Foreground="{StaticResource OnSurfaceBrush}" 
                                                  HorizontalAlignment="Center" LineHeight="1">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="White" Opacity="0.1"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <Border Background="#1a4edea3" 
                                               Padding="16,6" CornerRadius="16" Margin="0,16,0,0" HorizontalAlignment="Center">
                                            <TextBlock Text="SECURED" Foreground="#4edea3" 
                                                      FontWeight="Bold" FontSize="10"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Viewbox>
                        </Grid>

                        <!-- Status Indicators -->
                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="HEURISTICS" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding HeuristicsStatus}" 
                                          Foreground="{Binding HeuristicsStatus, Converter={StaticResource StatusToBrushConverter}}"
                                          FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.5" Duration="0:0:2"
                                                                     AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <SineEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>

                            <Rectangle Grid.Column="1" HorizontalAlignment="Center"
                                      Width="1" Height="40" VerticalAlignment="Center" 
                                      Fill="{StaticResource OutlineVariantBrush}" Opacity="0.15"/>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="BEHAVIORAL" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding BehavioralStatus}" 
                                          Foreground="{Binding BehavioralStatus, Converter={StaticResource StatusToBrushConverter}}"
                                          FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.5" Duration="0:0:2.5"
                                                                     AutoReverse="True">
                                                        <DoubleAnimation.EasingFunction>
                                                            <SineEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </StackPanel>

                            <Rectangle Grid.Column="3" HorizontalAlignment="Center"
                                      Width="1" Height="40" VerticalAlignment="Center"
                                      Fill="{StaticResource OutlineVariantBrush}" Opacity="0.15"/>

                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="ENTROPY" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding EntropyScoreText, StringFormat='{}{0} H/b'}" FontSize="18" FontWeight="Bold" 
                                          Foreground="{StaticResource SecondaryBrush}" 
                                          HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    </Viewbox>
                </Border>

                <!-- RIGHT: Active Alerts -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" 
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="{StaticResource SurfaceContainerHighestBrush}" 
                               Padding="10,6" CornerRadius="8,8,0,0">
                            <Grid>
                                <TextBlock Text="ACTIVE ALERTS" Style="{StaticResource TextLabel}" FontSize="10"/>
                                <Border Background="{StaticResource TertiaryContainerBrush}" 
                                       Padding="6,3" CornerRadius="3" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding NewAlertsText}" Foreground="{StaticResource OnTertiaryContainerBrush}" 
                                              FontWeight="Bold" FontSize="10"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                                     HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="8">
                                <!-- Empty State -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,48,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ActiveAlerts.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Viewbox Width="32" Height="32" Opacity="0.2" Margin="0,0,0,12">
                                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" Fill="{StaticResource OnSurfaceBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="No active threats" Style="{StaticResource TextSmall}" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" Opacity="0.5"/>
                                    <TextBlock Text="Your system is secured" Style="{StaticResource TextLabel}" FontSize="8" HorizontalAlignment="Center" Opacity="0.3" Margin="0,4,0,0"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding ActiveAlerts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SurfaceContainerBrush}" 
                                                   Margin="0,0,0,8" CornerRadius="6" ClipToBounds="True">
                                                <Grid>
                                                    <StackPanel Margin="10,8">
                                                        <Grid Margin="0,0,0,6">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,50,0">
                                                                <Viewbox Width="12" Height="12" Margin="0,0,6,0" VerticalAlignment="Top" FlowDirection="LeftToRight">
                                                                    <Path Data="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" 
                                                                          Fill="{StaticResource TertiaryBrush}"/>
                                                                </Viewbox>
                                                                <TextBlock Text="{Binding Name}" 
                                                                          Style="{StaticResource TextBody}" FontWeight="Bold" FontSize="12"
                                                                          TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Path, StringFormat='Target: {0}'}" 
                                                                  Style="{StaticResource TextSmall}" TextWrapping="Wrap" FontSize="10"/>
                                                        <Grid Margin="0,8,0,0" HorizontalAlignment="Right">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="6"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Button Content="IGNORE" Grid.Column="0" Width="60"
                                                                   Style="{StaticResource SleekGhostButton}"
                                                                   Command="{Binding DataContext.IgnoreAlertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"/>
                                                            <Button Content="QUARANTINE" Grid.Column="2" Width="85"
                                                                   Style="{StaticResource SleekDangerButton}"
                                                                   Command="{Binding DataContext.QuarantineAlertCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                   CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                    
                                                    <Border Background="{StaticResource TertiaryBrush}" Opacity="0.1" CornerRadius="0,0,0,6" 
                                                            HorizontalAlignment="Right" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding Severity}" Foreground="Transparent" 
                                                                   FontWeight="Black" FontSize="9" Padding="8,3"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Severity}" Foreground="{StaticResource TertiaryBrush}" 
                                                               FontWeight="Black" FontSize="9" Padding="8,3" 
                                                               HorizontalAlignment="Right" VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>

                        <Button Grid.Row="2" Content="VIEW ALL INCIDENT LOGS" Style="{StaticResource NativeButton}" 
                               Command="{Binding ViewAllLogsCommand}"
                               Margin="8" HorizontalAlignment="Center" Padding="10,5" FontSize="10"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- System Architecture Visualization (Decorative Section) -->
            <Border Grid.Row="3" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" ClipToBounds="True" MinHeight="140">
                <Grid>
                    <!-- Simulated Background Map / Data Flow placeholder -->
                    <Path Data="M0,0 L100,100" Stretch="Fill" Stroke="{StaticResource SurfaceContainerHighestBrush}" Opacity="0.1"/>
                    
                    <Grid Margin="20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Neural Protection Engine " FontSize="16" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                <TextBlock Text="v4.2.0" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="The Sentinel is currently employing deep-packet inspection and behavioral heuristics across all active network nodes. Protection is optimized for the current threat landscape." 
                                       Style="{StaticResource TextSmall}" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Left" Foreground="{StaticResource OnSurfaceVariantBrush}" FontSize="9"/>
                            

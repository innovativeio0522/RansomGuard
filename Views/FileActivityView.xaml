<UserControl x:Class="RansomGuard.Views.FileActivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource OnSurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            
            <!-- Page Header (Strict Adherence) -->
            <Grid Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="File Activity Monitor" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                    <Border Background="#1a4edea3" BorderBrush="#334edea3" BorderThickness="1" 
                            CornerRadius="4" Margin="16,0,0,0" Padding="8,2">
                        <TextBlock Text="LIVE STREAM" Foreground="#4edea3" 
                                   FontWeight="Bold" FontSize="10"/>
                    </Border>
                </StackPanel>

                <!-- Top Right Search & Utility -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Width="280" Height="32" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="14" Height="14" HorizontalAlignment="Left" Opacity="0.5">
                                <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                      Fill="{StaticResource OnSurfaceBrush}"/>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Search file paths or processes..." 
                                      FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" 
                                      VerticalAlignment="Center" Opacity="0.5" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Comprehensive Filter Bar (Responsive) -->
            <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Event Type Toggle -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,12">
                            <TextBlock Text="EVENT TYPE:" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Border Background="{StaticResource SurfaceContainerHighestBrush}" CornerRadius="4" Padding="4">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="All Events" Style="{StaticResource NativeButton}" Background="{StaticResource SurfaceVariantBrush}" FontWeight="Bold" Padding="12,6"/>
                                    <Button Content="Created" Style="{StaticResource NativeButton}" Background="Transparent" Foreground="{StaticResource OnSurfaceVariantBrush}" Padding="12,6"/>
                                    <Button Content="Modified" Style="{StaticResource NativeButton}" Background="Transparent" Foreground="{StaticResource OnSurfaceVariantBrush}" Padding="12,6"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Watch Directory Dropdown -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,12">
                            <TextBlock Text="WATCH DIRECTORY:" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Border Background="{StaticResource SurfaceContainerHighestBrush}" CornerRadius="4" Padding="12,6" Width="180">
                                <Grid>
                                    <TextBlock Text="/System/Library" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                                    <Path Data="M7,10L12,15L17,10H7Z" Fill="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Risk Level -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,12">
                            <TextBlock Text="RISK LEVEL:" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="LOW" Style="{StaticResource NativeButton}" Background="{StaticResource SurfaceVariantBrush}" Foreground="{StaticResource OnSurfaceBrush}" Opacity="0.8" Padding="14,6" Margin="0,0,8,0" BorderThickness="0"/>
                                <Button Content="MEDIUM" Style="{StaticResource NativeButton}" Background="{StaticResource SurfaceVariantBrush}" Foreground="{StaticResource OnSurfaceBrush}" Opacity="0.8" Padding="14,6" Margin="0,0,8,0" BorderThickness="0"/>
                                <Button Content="HIGH RISK" Style="{StaticResource DangerButton}" Background="#ffb3261e" Foreground="White" Padding="14,6" BorderThickness="0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Row Management (Pushed to end/wrapped) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                            <Button Style="{StaticResource NativeButton}" Background="Transparent" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" Padding="16,6" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                        <Path Data="M14,19H18V5H14M6,19H10V5H6V19Z" Fill="{StaticResource PrimaryBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="Pause Log" Foreground="{StaticResource PrimaryBrush}" FontWeight="ExtraBold" FontSize="11"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NativeButton}" Background="{StaticResource SurfaceContainerHighestBrush}" Padding="16,6" BorderThickness="0">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                        <Path Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z" Fill="{StaticResource OnSurfaceBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="Export CSV" FontWeight="ExtraBold" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                </WrapPanel>
            </Border>

            <!-- Activity Log Modern Table -->
            <Border Background="{StaticResource SurfaceContainerBrush}" CornerRadius="12" ClipToBounds="True">
                <StackPanel>
                    <!-- Table Header -->
                    <Grid Background="#1c202a" Height="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TIMESTAMP" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="24,0"/>
                        <TextBlock Grid.Column="1" Text="EVENT" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="FILE PATH" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="16,0"/>
                        <TextBlock Grid.Column="3" Text="PROCESS RESPONSIBLE" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="16,0"/>
                        <TextBlock Grid.Column="4" Text="ENTROPY SCORE" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                    </Grid>

                    <ItemsControl>
                        <!-- High Risk Row -->
                        <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Height="64">
                            <Grid Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="156"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="2023-10-27" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="14:22:01.045" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceBrush}" FontWeight="Bold"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#26ff5451" Padding="8,3" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="MODIFIED" Foreground="{StaticResource TertiaryContainerBrush}" FontWeight="Black" FontSize="9"/>
                                </Border>

                                <TextBlock Grid.Column="2" Text="/Users/Admin/Documents/Financials/Q4_Balance_Sheet.xlsx" 
                                           FontSize="12" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Margin="16,0" TextTrimming="CharacterEllipsis"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                        <Path Data="M12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22M12,20C9.64,20 7.54,18.9 6.22,17.1C6.25,15.17 10.07,14.1 12,14.1C13.93,14.1 17.75,15.17 17.78,17.1C16.46,18.9 14.36,20 12,20M12,6A3.5,3.5 0 0,1 15.5,9.5A3.5,3.5 0 0,1 12,13A3.5,3.5 0 0,1 8.5,9.5A3.5,3.5 0 0,1 12,6Z" Fill="{StaticResource TertiaryBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="ransomware.exe" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                    <TextBlock Text=" (PID: 8842)" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.5" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                </StackPanel>

                                <Border Grid.Column="4" Background="#1aff5451" BorderBrush="#33ff5451" BorderThickness="1" CornerRadius="16" Padding="12,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="#ff5451" Margin="0,0,8,0">
                                            <Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect>
                                        </Ellipse>
                                        <TextBlock Text="7.98" FontWeight="Black" FontSize="11" Foreground="#ff5451"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- System Row -->
                        <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Height="64">
                            <Grid Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="156"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="2023-10-27" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="14:21:58.112" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceBrush}" FontWeight="Bold"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#264edea3" Padding="8,3" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="MODIFIED" Foreground="#4edea3" FontWeight="Black" FontSize="9"/>
                                </Border>

                                <TextBlock Grid.Column="2" Text="/private/etc/hosts" 
                                           FontSize="12" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Margin="16,0" TextTrimming="CharacterEllipsis"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                        <Path Data="M20,19V7H4V19H20M20,3A2,2 0 0,1 22,5V19A2,2 0 0,1 20,21H4A2,2 0 0,1 2,19V5C2,3.89 2.9,3 4,3H20M13,17V15H18V17H13M9.58,13L12,15.41L11.41,16L8.17,12.76L11.41,9.53L12,10.12L9.58,12.53L9.58,13Z" Fill="{StaticResource OnSurfaceVariantBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="system_config" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                    <TextBlock Text=" (PID: 104)" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.5" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                </StackPanel>

                                <Border Grid.Column="4" Background="{StaticResource SurfaceVariantBrush}" CornerRadius="16" Padding="12,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="#4edea3" Margin="0,0,8,0"/>
                                        <TextBlock Text="3.12" FontWeight="Black" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Created Row -->
                        <Border BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Height="64">
                            <Grid Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="156"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="2023-10-27" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="14:21:55.980" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceBrush}" FontWeight="Bold"/>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#26adc6ff" Padding="8,3" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="CREATED" Foreground="{StaticResource PrimaryBrush}" FontWeight="Black" FontSize="9"/>
                                </Border>

                                <TextBlock Grid.Column="2" Text="/tmp/.hidden_temp_storage_0192" 
                                           FontSize="12" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Margin="16,0" TextTrimming="CharacterEllipsis"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                                    <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                        <Path Data="M12,2L4.5,20.29L5.21,21L12,18L18.79,21L19.5,20.29L12,2Z" Fill="{StaticResource OnSurfaceVariantBrush}"/>
                                    </Viewbox>
                                    <TextBlock Text="chrome.exe" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                    <TextBlock Text=" (PID: 4421)" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.5" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                </StackPanel>

                                <Border Grid.Column="4" Background="{StaticResource SurfaceVariantBrush}" CornerRadius="16" Padding="12,4" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="#4edea3" Margin="0,0,8,0"/>
                                        <TextBlock Text="4.45" FontWeight="Black" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Bottom Intelligence Cluster (Bento) -->
            <Grid Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Entropy Distribution Chart -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerBrush}" CornerRadius="16" Padding="24">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="ENTROPY DISTRIBUTION" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <Viewbox Width="16" Height="16" HorizontalAlignment="Right">
                                <Path Data="M17.45,15.18L15.84,19.17C15.64,19.66 15.13,20 14.56,20H9.44C8.87,20 8.35,19.66 8.16,19.17L6.55,15.18C6.33,14.62 6.53,13.97 7.05,13.62L10.33,11.33L7.05,9.04C6.53,8.68 6.33,8.04 6.55,7.48L8.16,3.49C8.35,3 8.87,2.66 9.44,2.66H14.56C15.13,2.66 15.64,3 15.84,3.49L17.45,7.48C17.67,8.04 17.47,8.68 16.95,9.04L13.67,11.33L16.95,13.62C17.47,13.97 17.67,14.62 17.45,15.18Z" Fill="{StaticResource PrimaryBrush}"/>
                            </Viewbox>
                        </Grid>
                        
                        <!-- Visual Wave Distribution -->
                        <Grid Height="90" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Height="90">
                                <Rectangle Width="24" Height="30" Fill="{StaticResource PrimaryBrush}" Opacity="0.2" Margin="0,0,4,0" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="24" Height="45" Fill="{StaticResource PrimaryBrush}" Opacity="0.2" Margin="0,0,4,0" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="24" Height="60" Fill="{StaticResource PrimaryBrush}" Opacity="0.3" Margin="0,0,4,0" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="24" Height="85" Fill="{StaticResource PrimaryBrush}" Opacity="0.5" Margin="0,0,4,0" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="24" Height="50" Fill="{StaticResource PrimaryBrush}" Opacity="0.3" Margin="0,0,4,0" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                                <Rectangle Width="24" Height="95" Fill="{StaticResource TertiaryContainerBrush}" Margin="0,0,4,0" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2">
                                    <Rectangle.Effect><DropShadowEffect Color="{StaticResource Tertiary}" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/></Rectangle.Effect>
                                </Rectangle>
                                <Rectangle Width="24" Height="25" Fill="{StaticResource PrimaryBrush}" Opacity="0.2" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <TextBlock Text="Low Noise (Clear)" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Text="High Randomness (Encrypted?)" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TertiaryContainerBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- I/O Intensive Nodes -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerBrush}" CornerRadius="16" Padding="24">
                    <StackPanel>
                        <TextBlock Text="I/O INTENSIVE NODES" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,0,20"/>
                        
                        <StackPanel Margin="0,0,0,16">
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" Background="{StaticResource SurfaceVariantBrush}" CornerRadius="4">
                                        <TextBlock Text="01" FontSize="9" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="msmpeng.exe" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="842MB/s" FontSize="10" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar Height="4" Value="80" Maximum="100" Background="{StaticResource SurfaceContainerHighestBrush}" Foreground="{StaticResource SecondaryBrush}" BorderThickness="0"/>
                        </StackPanel>

                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="24" Background="{StaticResource SurfaceVariantBrush}" CornerRadius="4">
                                        <TextBlock Text="02" FontSize="9" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="backup_agent" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="211MB/s" FontSize="10" FontFamily="Consolas" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <ProgressBar Height="4" Value="45" Maximum="100" Background="{StaticResource SurfaceContainerHighestBrush}" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Statistics Summary -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerBrush}" CornerRadius="16" Padding="24" VerticalAlignment="Stretch">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="12.4k" FontSize="42" FontWeight="Black" Foreground="#ff5451" HorizontalAlignment="Center">
                                <TextBlock.Effect><DropShadowEffect Color="#ff5451" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/></TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="EVENTS SCANNED / MIN" FontSize="10" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            
                            <Border Background="#1a4edea3" BorderBrush="#334edea3" BorderThickness="1" CornerRadius="20" Padding="12,6" Margin="0,20,0,0" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#4edea3" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="Zero Anomalies Detected" FontSize="10" FontWeight="Bold" Foreground="#4edea3"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

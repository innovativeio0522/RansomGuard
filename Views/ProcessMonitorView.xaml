<UserControl x:Class="RansomGuard.Views.ProcessMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource OnSurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24">
            
            <!-- Page Header -->
            <Grid Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Process Monitor" FontSize="20" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                    <Rectangle Width="1" Height="20" Fill="{StaticResource OutlineVariantBrush}" Margin="16,0"/>
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="SYSTEM NOMINAL" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <Border HorizontalAlignment="Right" Background="{StaticResource SurfaceVariantBrush}" CornerRadius="20" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                            <Path Data="M15.5,14h-0.79l-0.28-0.27C15.41,12.59,16,11.11,16,9.5C16,5.91,13.09,3,9.5,3S3,5.91,3,9.5S5.91,16,9.5,16c1.61,0,3.09-0.59,4.23-1.57L14,14.71v0.79l5,4.99L20.49,19L15.5,14z M9.5,14C7.01,14,5,11.99,5,9.5S7.01,5,9.5,5S14,7.01,14,9.5S11.99,14,9.5,14z" 
                                  Fill="{StaticResource OnSurfaceVariantBrush}"/>
                        </Viewbox>
                        <TextBlock Text="Search PID or Name..." FontSize="11" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Metrics Bento Cluster -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Active Threads -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="24" Height="140">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="ACTIVE THREADS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Text="1,248" FontSize="42" FontWeight="Black" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                            <Border Background="{StaticResource SecondaryBrush}" Opacity="0.1" CornerRadius="4" Width="70" Height="20" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                            <TextBlock Text="+12%  Last 5 min" FontSize="9" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" Margin="6,-18,0,0"/>
                        </StackPanel>
                        <Viewbox Width="48" Height="48" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.1">
                            <Path Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5Z" 
                                  Fill="{StaticResource OnSurfaceBrush}"/>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- CPU Load -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="24" Height="140">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="CPU LOAD" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Text="18.4%" FontSize="42" FontWeight="Black" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,8,0,0"/>
                            <ProgressBar Height="4" Value="18.4" Maximum="100" Margin="0,16,0,0" VerticalAlignment="Bottom"
                                        Background="{StaticResource SurfaceContainerHighestBrush}" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"/>
                        </StackPanel>
                        <Viewbox Width="48" Height="48" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.1">
                            <Path Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M13,7H11V12.41L15.29,16.71L16.71,15.29L13,11.59V7Z" 
                                  Fill="{StaticResource OnSurfaceBrush}"/>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- Trusted Proc -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="24" Height="140">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="TRUSTED PROC" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Text="99.2%" FontSize="42" FontWeight="Black" Foreground="{StaticResource SecondaryBrush}" Margin="0,8,0,0"/>
                            <TextBlock Text="Verification: Active" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,8,0,0" Opacity="0.8"/>
                        </StackPanel>
                        <Viewbox Width="48" Height="48" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.1">
                            <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" 
                                  Fill="{StaticResource OnSurfaceBrush}"/>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- Suspicious -->
                <Border Grid.Column="6" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="24" Height="140"
                        BorderBrush="{StaticResource TertiaryBrush}" BorderThickness="4,0,0,0">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="SUSPICIOUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Text="01" FontSize="42" FontWeight="Black" Foreground="{StaticResource TertiaryBrush}" Margin="0,8,0,0"/>
                            <TextBlock Text="ACTION REQUIRED" FontSize="9" FontWeight="Black" Foreground="{StaticResource TertiaryBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                        <Viewbox Width="48" Height="48" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.1">
                            <Path Data="M13,14H11V9H13M13,18H11V16H13M1,21H23L12,2L1,21Z" 
                                  Fill="{StaticResource OnSurfaceBrush}"/>
                        </Viewbox>
                    </Grid>
                </Border>
            </Grid>

            <!-- Table Section -->
            <Border Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" ClipToBounds="True">
                <StackPanel>
                    <Border Padding="24,20" Background="{StaticResource SurfaceVariantBrush}" Opacity="0.5">
                        <Grid>
                            <TextBlock Text="Active System Processes" FontSize="13" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="EXPORT LOGS" Style="{StaticResource NativeButton}" FontSize="10" FontWeight="Bold" Padding="16,8" Margin="0,0,12,0" Background="Transparent" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="1"/>
                                <Button Content="REFRESH (5S)" Style="{StaticResource PrimaryButton}" FontSize="10" FontWeight="Bold" Padding="16,8" Background="#ff4d8eff"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Table Header -->
                    <Border Padding="24,12" Background="{StaticResource SurfaceContainerBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PROCESS NAME" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="1" Text="PID" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="CPU %" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="3" Text="MEMORY (MB)" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="4" Text="DISK I/O" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="5" Text="TRUST STATUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Row 1: suspicious -->
                    <Border Padding="24,16" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0">
                                    <Path Data="M10,4H4C2.89,4 2.01,4.89 2.01,6L2,18C2,19.11 2.89,20 4,20H20C21.11,20 22,19.11 22,18V8C22,6.89 21.11,6 20,6H12L10,4Z" 
                                          Fill="{StaticResource TertiaryBrush}" Opacity="0.5"/>
                                </Viewbox>
                                <TextBlock Text="unknown_process.exe" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource TertiaryBrush}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="8421" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="14.2%" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TertiaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ProgressBar Width="60" Height="2" Value="14.2" Maximum="100" VerticalAlignment="Center" Background="{StaticResource SurfaceContainerHighestBrush}" Foreground="{StaticResource TertiaryBrush}" BorderThickness="0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3" Text="1,024.0" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Opacity="0.8"/>
                            <TextBlock Grid.Column="4" Text="HIGH WRITE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TertiaryBrush}" VerticalAlignment="Center"/>

                            <Border Grid.Column="5" Background="{StaticResource TertiaryBrush}" Padding="8,4" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="SUSPICIOUS" Foreground="{StaticResource OnTertiaryContainerBrush}" FontWeight="Black" FontSize="9"/>
                            </Border>

                            <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Kill Process" Style="{StaticResource DangerButton}" FontSize="10" FontWeight="Bold" Padding="12,6" Margin="0,0,8,0" Foreground="White" Background="#ffb3261e"/>
                                <Button Content="Whitelist" Style="{StaticResource NativeButton}" FontSize="10" FontWeight="Bold" Padding="12,6" Background="#1a4edea3" Foreground="{StaticResource OnSurfaceBrush}" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 2: explorer.exe -->
                    <Border Padding="24,16" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0">
                                    <Path Data="M10,4H4C2.89,4 2.01,4.89 2.01,6L2,18C2,19.11 2.89,20 4,20H20C21.11,20 22,19.11 22,18V8C22,6.89 21.11,6 20,6H12L10,4Z" 
                                          Fill="{StaticResource SecondaryBrush}" Opacity="0.5"/>
                                </Viewbox>
                                <TextBlock Text="explorer.exe" FontFamily="Consolas" FontSize="13" Foreground="{StaticResource OnSurfaceBrush}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="2940" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="1.2%" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ProgressBar Width="60" Height="2" Value="1.2" Maximum="100" VerticalAlignment="Center" Background="{StaticResource SurfaceContainerHighestBrush}" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3" Text="154.2" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Opacity="0.8"/>
                            <TextBlock Grid.Column="4" Text="IDLE" FontSize="10" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Opacity="0.6"/>

                            <Border Grid.Column="5" Background="{StaticResource SecondaryBrush}" Opacity="0.2" Padding="8,4" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="TRUSTED" Foreground="{StaticResource SecondaryBrush}" FontWeight="Black" FontSize="9"/>
                            </Border>

                            <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Kill Process" Style="{StaticResource NativeButton}" FontSize="10" FontWeight="Bold" Padding="12,6" Margin="0,0,8,0" Background="Transparent" Foreground="{StaticResource OnSurfaceBrush}"/>
                                <Button Content="Whitelisted" Style="{StaticResource NativeButton}" FontSize="10" FontWeight="Bold" Padding="12,6" Background="#ff1e5135" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Bottom Dashboard Section -->
            <Grid Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- System Execution Timeline (Strict Adherence to Image 2) -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="24" VerticalAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="SYSTEM EXECUTION TIMELINE" FontSize="11" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Kernel" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,12,0"/>
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="User" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Bottom-Aligned Bar Chart (Individual Bottom Anchoring) -->
                        <Grid Height="160">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                                <Border Width="30" Height="35" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.3" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="55" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.3" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="40" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.3" VerticalAlignment="Bottom"/>
                                
                                <!-- User activity peaks -->
                                <Border Width="30" Height="90" Background="#264edea3" Margin="1,0" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="70" Background="#264edea3" Margin="1,0" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="110" Background="#264edea3" Margin="1,0" VerticalAlignment="Bottom"/>
                                
                                <!-- Anomaly center peak -->
                                <Border Width="30" Height="150" Background="#40ff5451" Margin="1,0" VerticalAlignment="Bottom"/>
                                
                                <!-- Kernel/System Descending -->
                                <Border Width="30" Height="45" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="30" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="20" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="80" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="70" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="65" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="85" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="50" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="35" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="85" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="40" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                                <Border Width="30" Height="25" Background="{StaticResource SurfaceVariantBrush}" Margin="1,0" Opacity="0.4" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Alert Detail (Strict Adherence) -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Text="ALERT DETAIL" FontSize="11" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <Viewbox Width="20" Height="20" HorizontalAlignment="Right">
                                <Path Data="M13,14H11V9H13M13,18H11V16H13M1,21H23L12,2L1,21Z" Fill="{StaticResource TertiaryBrush}"/>
                            </Viewbox>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="unknown_process.exe" FontSize="16" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}" Margin="0,16,0,4"/>
                        <TextBlock Grid.Row="2" Text="Process attempting to open a raw socket on port 4444. This behavior is indicative of a reverse shell attempt." 
                                 FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" Opacity="0.8" TextWrapping="Wrap" Margin="0,8,0,24"/>

                        <Border Grid.Row="3" Background="{StaticResource BackgroundBrush}" CornerRadius="4" Padding="16,12" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PATH:" FontSize="9" FontWeight="Black" Foreground="{StaticResource TertiaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="C:\Users\Admin\AppData\Local\Temp\..." Style="{StaticResource TextMono}" FontSize="10" Foreground="{StaticResource OnSurfaceBrush}" Opacity="0.9" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Grid.Row="4" Content="QUARANTINE IMMEDIATELY" Style="{StaticResource DangerButton}" 
                               Height="48" Margin="0,24,0,0" FontSize="11" FontWeight="Black"/>
                    </Grid>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

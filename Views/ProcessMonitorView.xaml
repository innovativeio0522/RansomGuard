<UserControl x:Class="RansomGuard.Views.ProcessMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}"
             Foreground="{StaticResource OnSurfaceBrush}"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Page Header -->
            <RowDefinition Height="*"/>    <!-- Main Content (Scrollable) -->
        </Grid.RowDefinitions>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Metrics Bento Cluster -->
                <RowDefinition Height="*"/>    <!-- Table Section (Fills Gap) -->
                <RowDefinition Height="Auto"/> <!-- Bottom Dashboard Section -->
            </Grid.RowDefinitions>
            
            <!-- Metrics Bento Cluster -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Active Threads -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ActiveThreads}" FontSize="26" FontWeight="Black"
                                   Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                    <Path Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5Z" 
                                          Fill="{StaticResource OnSurfaceVariantBrush}"/>
                                </Viewbox>
                                <TextBlock Text="ACTIVE THREADS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                            <TextBlock Text="+12%  Last 5 min" FontSize="8" Foreground="{StaticResource SecondaryBrush}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CPU Load -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CpuLoad}" FontSize="26" FontWeight="Black"
                                   Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                    <Path Data="M12,2C6.48,2 2,6.48 2,12C2,17.52 6.48,22 12,22C17.52,22 22,17.52 22,12C22,6.48 17.52,2 12,2M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M13,7H11V12.41L15.29,16.71L16.71,15.29L13,11.59V7Z" 
                                          Fill="{StaticResource OnSurfaceVariantBrush}"/>
                                </Viewbox>
                                <TextBlock Text="CPU LOAD" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                            <ProgressBar Height="3" Value="{Binding CpuLoadValue}" Maximum="100" Margin="0,5,0,0"
                                        Background="{StaticResource SurfaceContainerHighestBrush}" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Trusted Proc -->
                <Border Grid.Column="4" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding TrustedProcPercent}" FontSize="26" FontWeight="Black"
                                   Foreground="{StaticResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                    <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z" 
                                          Fill="{StaticResource SecondaryBrush}"/>
                                </Viewbox>
                                <TextBlock Text="TRUSTED PROC" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Verification: Active" FontSize="8" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Suspicious -->
                <Border Grid.Column="6" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="8" Padding="14,10"
                        BorderBrush="{StaticResource TertiaryBrush}" BorderThickness="3,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding SuspiciousCount}" FontSize="26" FontWeight="Black"
                                   Foreground="{StaticResource TertiaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="12" Height="12" Margin="0,0,5,0">
                                    <Path Data="M13,14H11V9H13M13,18H11V16H13M1,21H23L12,2L1,21Z" 
                                          Fill="{StaticResource TertiaryBrush}"/>
                                </Viewbox>
                                <TextBlock Text="SUSPICIOUS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                            <TextBlock Text="ACTION REQUIRED" FontSize="8" Foreground="{StaticResource TertiaryBrush}" FontWeight="Bold" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Table Section -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Status Bar -->
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Data List -->
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="24,8" Background="{StaticResource SurfaceVariantBrush}" Opacity="0.5">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Active System Processes" FontSize="13" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"/>
                                <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ActiveProcesses.Count}" FontSize="10" FontWeight="Black" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Auto-refresh: 3s" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" VerticalAlignment="Center" Margin="0,0,16,0" Opacity="0.7"/>
                                <Button Content="EXPORT LOGS" Command="{Binding ExportLogsCommand}" Style="{StaticResource NativeButton}" FontSize="10" FontWeight="Bold" Padding="12,5" Margin="0,0,12,0" Background="Transparent" BorderThickness="0"/>
                                <Button Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Padding="12,5" Background="#ff4d8eff">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,8,0">
                                            <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" 
                                                  Fill="White"/>
                                        </Viewbox>
                                        <TextBlock Text="REFRESH" FontSize="10" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Table Header -->
                    <Border Grid.Row="1" Padding="24,4" Background="{StaticResource SurfaceContainerBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PROCESS NAME" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="1" Text="PID" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="CPU %" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="3" Text="MEMORY (MB)" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="4" Text="DISK I/O" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <TextBlock Grid.Column="5" Text="TRUST STATUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="ACTIONS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource OnSurfaceVariantBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="2" ItemsSource="{Binding ActiveProcesses}" SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <EventSetter Event="RequestBringIntoView" Handler="ListBoxItem_RequestBringIntoView"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- Hover effect -->
                                                <Trigger Property="IsMouseOver" Value="true">
                                                    <Setter Property="Background" TargetName="Bd" Value="{StaticResource SurfaceVariantBrush}"/>
                                                </Trigger>
                                                <!-- Selected effect -->
                                                <Trigger Property="IsSelected" Value="true">
                                                    <Setter Property="Background" TargetName="Bd" Value="{StaticResource SurfaceContainerHighestBrush}"/>
                                                    <!-- Optional subtle left-border indicator for selected row -->
                                                    <Setter Property="BorderBrush" TargetName="Bd" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="BorderThickness" TargetName="Bd" Value="3,0,0,0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="21,2" Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                                <Path Data="M10,4H4C2.89,4 2.01,4.89 2.01,6L2,18C2,19.11 2.89,20 4,20H20C21.11,20 22,19.11 22,18V8C22,6.89 21.11,6 20,6H12L10,4Z" 
                                                      Fill="{StaticResource PrimaryBrush}" Opacity="0.5"/>
                                            </Viewbox>
                                            <TextBlock Text="{Binding Name}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding Pid}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F1}%}" 
                                                     FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"
                                                     Foreground="{Binding CpuUsage, Converter={StaticResource LoadToBrushConverter}}"/>
                                            <ProgressBar Width="50" Height="4" Value="{Binding CpuUsage}" Maximum="100" VerticalAlignment="Center" 
                                                        Background="{StaticResource SurfaceContainerHighestBrush}" 
                                                        Foreground="{Binding CpuUsage, Converter={StaticResource LoadToBrushConverter}}" 
                                                        BorderThickness="0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" Text="{Binding MemoryMb, StringFormat={}{0:F1}}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource OnSurfaceBrush}" VerticalAlignment="Center" Opacity="0.8"/>
                                        
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Opacity="0.8">
                                            <Ellipse Width="5" Height="5" Fill="{Binding IoRate, Converter={StaticResource IoToBrushConverter}}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding IoRate, Converter={StaticResource IoToStatusConverter}}" FontSize="9" Foreground="{StaticResource OnSurfaceBrush}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="5" Text="{Binding SignatureStatus}" 
                                                   Foreground="{Binding IsTrusted, Converter={StaticResource TrustToBrushConverter}}" 
                                                   FontWeight="Bold" FontSize="9" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" ToolTip="{Binding SignatureStatus}"/>

                                        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Kill Process" Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource SleekDangerButton}" Margin="0,0,6,0"/>
                                            <Button Command="{Binding DataContext.WhitelistProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Style="{StaticResource SleekGhostButton}">
                                                <Button.Content>
                                                    <TextBlock Text="{Binding WhitelistActionText}" FontSize="9" FontWeight="Bold"/>
                                                </Button.Content>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Bottom Dashboard Section -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- System Execution Timeline -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="16" VerticalAlignment="Stretch">
                    <StackPanel>

                        <!-- Header row -->
                        <Grid Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="CPU EXECUTION TIMELINE" FontSize="11" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                                <TextBlock Text="Last 60 seconds of kernel vs. user activity" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.55" Margin="0,2,0,0"/>
                            </StackPanel>
                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Kernel" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}" Margin="0,0,14,0"/>
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="User" FontSize="10" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Live metric callouts -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Kernel metric -->
                            <Border Grid.Column="0" Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,6,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="KERNEL (PRIVILEGED)" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding KernelCpuText}" FontSize="20" FontWeight="Black" Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="OS &amp; driver activity" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.5" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- User metric -->
                            <Border Grid.Column="1" Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="10,6" Margin="6,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource SecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="USER (PROCESS)" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.7"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding UserCpuText}" FontSize="20" FontWeight="Black" Foreground="{StaticResource SecondaryBrush}"/>
                                    <TextBlock Text="App &amp; process activity" FontSize="9" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.5" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Bar chart with Y-axis grid lines -->
                        <Grid Height="110" ClipToBounds="True">
                            <!-- Y-axis reference lines -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Opacity="0.2">
                                <TextBlock Text="100%" FontSize="8" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.4" VerticalAlignment="Top"/>
                            </Border>
                            <Border Grid.Row="1" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Opacity="0.2">
                                <TextBlock Text="75%" FontSize="8" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.4" VerticalAlignment="Top"/>
                            </Border>
                            <Border Grid.Row="2" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Opacity="0.2">
                                <TextBlock Text="50%" FontSize="8" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.4" VerticalAlignment="Top"/>
                            </Border>
                            <Border Grid.Row="3" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1" Opacity="0.2">
                                <TextBlock Text="25%" FontSize="8" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.4" VerticalAlignment="Top"/>
                            </Border>

                            <!-- Bars -->
                            <ItemsControl Grid.Row="0" Grid.RowSpan="4" ItemsSource="{Binding CpuHistory}" VerticalAlignment="Bottom">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="1,0">
                                            <Border Width="9" Height="{Binding KernelH}" Background="{StaticResource PrimaryBrush}"
                                                    Opacity="0.9" VerticalAlignment="Bottom" CornerRadius="2,2,0,0"/>
                                            <Border Width="9" Height="{Binding UserH}" Background="{StaticResource SecondaryBrush}"
                                                    Opacity="0.8" VerticalAlignment="Bottom" CornerRadius="2,2,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Process Detail Panel -->
                <Border Grid.Column="2" Background="{StaticResource SurfaceContainerLowBrush}" CornerRadius="12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header: label + dynamic trust icon -->
                        <Grid Grid.Row="0">
                            <TextBlock Text="PROCESS DETAIL" FontSize="11" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}"/>
                            <!-- Shield = trusted -->
                            <Viewbox Width="18" Height="18" HorizontalAlignment="Right">
                                <Viewbox.Style>
                                    <Style TargetType="Viewbox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProcess.IsTrusted}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Viewbox.Style>
                                <Path Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M10,17L6,13L7.41,11.59L10,14.17L16.59,7.58L18,9L10,17Z" Fill="{StaticResource SecondaryBrush}"/>
                            </Viewbox>
                            <!-- Warning = untrusted -->
                            <Viewbox Width="18" Height="18" HorizontalAlignment="Right">
                                <Viewbox.Style>
                                    <Style TargetType="Viewbox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProcess.IsTrusted}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Viewbox.Style>
                                <Path Data="M13,14H11V9H13M13,18H11V16H13M1,21H23L12,2L1,21Z" Fill="{StaticResource TertiaryBrush}"/>
                            </Viewbox>
                        </Grid>

                        <!-- Process name -->
                        <TextBlock Grid.Row="1" Text="{Binding SelectedProcess.Name, FallbackValue='No process selected'}"
                                   FontSize="16" FontWeight="Bold" Foreground="{StaticResource OnSurfaceBrush}"
                                   Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                        
                        <!-- Trust badge (dynamically coloured) -->
                        <Border Grid.Row="2" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left" Margin="0,6,0,12"
                                Background="{Binding SelectedProcess.IsTrusted, Converter={StaticResource TrustToBrushConverter}}">
                            <TextBlock Text="{Binding SelectedProcess.SignatureStatus, FallbackValue='Unknown'}"
                                       FontSize="10" FontWeight="Bold" Foreground="{StaticResource BackgroundBrush}"/>
                        </Border>

                        <!-- Stats block -->
                        <StackPanel Grid.Row="3" VerticalAlignment="Top" Background="{StaticResource BackgroundBrush}">
                            <Border Padding="12,6" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="PID" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="{Binding SelectedProcess.Pid, FallbackValue='—'}" FontSize="10"
                                               Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Right" FontFamily="Consolas"/>
                                </Grid>
                            </Border>
                            <Border Padding="12,6" BorderBrush="{StaticResource OutlineVariantBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBlock Text="CPU" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="{Binding SelectedProcess.CpuUsage, StringFormat={}{0:F1}%}" FontSize="10"
                                               Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Right" FontFamily="Consolas"/>
                                </Grid>
                            </Border>
                            <Border Padding="12,6">
                                <Grid>
                                    <TextBlock Text="MEM" FontSize="9" FontWeight="Black" Foreground="{StaticResource OnSurfaceVariantBrush}" Opacity="0.6"/>
                                    <TextBlock Text="{Binding SelectedProcess.MemoryMb, StringFormat={}{0:F1} MB}" FontSize="10"
                                               Foreground="{StaticResource OnSurfaceBrush}" HorizontalAlignment="Right" FontFamily="Consolas"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Action button: Red for untrusted, subtle for trusted -->
                        <Button Grid.Row="4" Command="{Binding KillProcessCommand}" CommandParameter="{Binding SelectedProcess}"
                                Height="36" Margin="0,12,0,0" FontSize="11" FontWeight="Black">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NativeButton}">
                                    <Setter Property="Content" Value="TERMINATE PROCESS"/>
                                    <Setter Property="Background" Value="{StaticResource SurfaceContainerHighBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource OnSurfaceBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProcess.IsTrusted}" Value="False">
                                            <Setter Property="Background" Value="{StaticResource TertiaryContainerBrush}"/>
                                            <Setter Property="Foreground" Value="{StaticResource OnTertiaryContainerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
